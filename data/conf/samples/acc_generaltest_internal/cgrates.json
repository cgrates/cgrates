{
// CGRateS Configuration file
//


"general": {
	"replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080"
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",
				"opts":{
				"internalDBRewriteInterval": "0s",
				"internalDBDumpInterval": "0s"
		}
		}
	}
},



"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": ".cgr.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/testit",
		"tpOutPath": "",
	},
],


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*localhost"]}],
		"*resources": [{"connIDs": ["*localhost"]}],
		"*accounts": [{"connIDs": ["*localhost"]}]
	},
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1"
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
	"*resources": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
	"*attributes": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
	"*rates": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
	"*cdrs": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
	"*chargers": [
		 	{
		 		"Tenant": "",
		 		"FilterIDs": [],
		 		"connIDs": ["*internal"]
		 	}
	],
			},
},


"admins": {
	"enabled": true,
},


"rates": {
	"enabled": true
},


"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"connIDs": ["*localhost"]}]
	},
},


"accounts": {
	"enabled": true
},


"filters": {
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}],
		"*accounts": [{"connIDs": ["*internal"]}]
	},
},

}
