{
// CGRateS Configuration file


"general": {
	"reply_timeout": "30s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": ":2012",
	"rpc_gob": ":2013",
	"http": ":2080",
},


"db": {
	"db_conns": {
		"*default": {
			"db_type": "mongo",
			"db_host": "127.0.0.1",	
			"db_port": 27017,
			"db_name": "10",
			"db_user": "cgrates"
		},
		"StorDB": {						
			"db_type": "mongo",		
			"db_host": "127.0.0.1",	
			"db_port": 27017,
			"db_name": "cgrates",
			"db_user": "cgrates"
		},
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"store_interval": "1s",
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",

	"users_filters":["Account"],
},


"admins": {
	"enabled": true,
},


"rates": {
	"enabled": true
},

"loaders": [
	{
		"enabled":true,
		"id": "*default",
		"tenant": "cgrates.org",
		"tp_in_dir": "/usr/share/cgrates/tariffplans/tutorial",
		"tp_out_dir": "",
		"lockfile_path": "",
	},
],

"filters": {								
	"conns": {
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"accounts": {
	"enabled": true
},


"analyzers":{									// AnalyzerS config
	"enabled": true,							// starts AnalyzerS service: <true|false>.
 	"db_path": "/tmp/analyzers",				// path to the folder where to store the information
},


}
