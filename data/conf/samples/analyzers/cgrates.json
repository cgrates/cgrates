{
// CGRateS Configuration file


"general": {
	"replyTimeout": "30s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {						
			"dbType": "mongo",		
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		},
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",

	"usersFilters":["Account"],
},


"admins": {
	"enabled": true,
},


"rates": {
	"enabled": true
},

"loaders": [
	{
		"enabled":true,
		"id": "*default",
		"tenant": "cgrates.org",
		"tpInPath": "/usr/share/cgrates/tariffplans/tutorial",
		"tpOutPath": "",
		"lockfilePath": "",
	},
],

"filters": {								
	"conns": {
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"accounts": {
	"enabled": true
},


"analyzers":{									// AnalyzerS config
	"enabled": true,							// starts AnalyzerS service: <true|false>.
 	"dbPath": "/tmp/analyzers",				// path to the folder where to store the information
},


}
