{
    // CGRateS Configuration file
    // will be used in apis/actions_it_test.go
  
    "logger": {
      "level": 7
    },

    "db": {
      "db_conns": {
		    "*default": {
         "db_type": "*internal",
         "opts":{
		      "internalDBRewriteInterval": "0s",
		      "internalDBDumpInterval": "0s"
	      }
	      }
	    }
    },
  
    "actions": {
        "enabled": true,
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}],
        	"*stats": [{"ConnIDs": ["*internal"]}]
        },
    },

    "stats": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },

    "thresholds": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*actions": [{"ConnIDs": ["*internal"]}]
        },
    },
  
    "admins": {
      "enabled": true,
    },
  }