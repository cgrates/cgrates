{
    // CGRateS Configuration file
    // will be used in apis/actions_it_test.go
  
    "logger": {
        "level": 7
    },

    "db": {
        "dbConns": {
		    "*default": {
                "dbType": "mongo",
                "dbName": "10",
                "dbPort": 27017,
	        },
            "StorDB": {						 // The id of the DB connection
                "dbType": "mongo",			 // db type: <internal|redis|mysql|mongo|postgres>
                "dbHost": "127.0.0.1",	
                "dbPort": 27017,			 // db port to reach the database
                "dbName": "cgrates",		 // the host to connect to
                "dbUser": "cgrates",
            },
        },
        "items": {
            "*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
        }
    },
  
    "actions": {
        "enabled": true,
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}],
        	"*stats": [{"ConnIDs": ["*internal"]}]
        },
    },

    "stats": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },

    "thresholds": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*actions": [{"ConnIDs": ["*internal"]}]
        },
    },
  
    "admins": {
      "enabled": true,
    }
}