{

"logger": {
    "level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",	
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
    	},
		"StorDB": {
			"dbType": "postgres",
			"dbHost": "127.0.0.1",
			"dbPort": 5432,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"},
		"*actionProfiles": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"},
	}
},

"actions": {
    "enabled": true,
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}],
    	"*stats": [{"connIDs": ["*internal"]}],
    	"*accounts": [{"connIDs": ["*internal"]}]
    },
},

"accounts": {
    "enabled": true
},

"stats": {
    "enabled": true,
    "storeInterval": "-1",
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}]
    },
},

"thresholds": {	
    "enabled": true,
    "storeInterval": "-1",
    "conns": {
    	"*actions": [{"connIDs": ["*internal"]}]
    },
},

"admins": {
    "enabled": true
}

}