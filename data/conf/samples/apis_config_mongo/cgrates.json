{
  // CGRateS Configuration file


  "general": {
    "replyTimeout": "30s",
    "cachingDelay": "1s",
  },

  "logger": {
    "level": 7
  },

  "listen": {
    "rpcJSON": ":2012",
    "rpcGOB": ":2013",
    "http": ":2080",
  },


  "db": {
    "dbConns": {
		"*default": {
      "dbType": "mongo",
      "dbHost": "127.0.0.1",	
      "dbPort": 27017,
      "dbName": "10",
			"dbUser": "cgrates"
	    },
      "StorDB": {						 // The id of the DB connection
        "dbType": "mongo",			 // db type: <internal|redis|mysql|mongo|postgres>
        "dbHost": "127.0.0.1",	
        "dbPort": 27017,			 // db port to reach the database
        "dbName": "cgrates",		 // the host to connect to
        "dbUser": "cgrates"
      }
    },
    "items": {
      "*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
    }
  },

  "cdrs": {
    "enabled": true,
    "conns": {
    	"*chargers": [{"ConnIDs": ["*internal"]}]
    },
  },


  "attributes": {
    "enabled": true,
    "conns": {
    	"*stats": [{"ConnIDs": ["*localhost"]}],
    	"*resources": [{"ConnIDs": ["*localhost"]}],
    	"*accounts": [{"ConnIDs": ["*localhost"]}]
    },
  },


  "chargers": {
    "enabled": true,
    "conns": {
    	"*attributes": [{"ConnIDs": ["*internal"]}]
    },
  },


  "resources": {
    "enabled": true,
    "storeInterval": "1s",
    "conns": {
    	"*thresholds": [{"ConnIDs": ["*internal"]}]
    },
  },


  "stats": {
    "enabled": true,
    "storeInterval": "1s",
    "conns": {
    	"*thresholds": [{"ConnIDs": ["*internal"]}]
    },
  },


  "thresholds": {
    "enabled": true,
    "storeInterval": "1s",
  },


  "routes": {
    "enabled": true,
    "prefixIndexedFields":["*req.Destination"],
    "conns": {
    	"*stats": [{"ConnIDs": ["*internal"]}],
    	"*resources": [{"ConnIDs": ["*internal"]}],
    	"*rates": [{"ConnIDs": ["*internal"]}]
    },
  },


  "sessions": {
    "enabled": true,
    "conns":{
    "*routes": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*resources": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*attributes": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*cdrs": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*chargers": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ]
            },
  },


  "migrator": {
    "out_datadb_type": "mongo",
    "out_datadb_port": "27017",
    "out_datadb_name": "10",
    "usersFilters":["Account"],
  },


  "admins": {
    "enabled": true,
  },


  "rates": {
    "enabled": false
  },



  "actions": {
    "enabled": true,
    "conns": {
    	"*accounts": [{"ConnIDs": ["*localhost"]}]
    },
  },


  "accounts": {
    "enabled": true
  },


  "filters": {
    "conns": {
    	"*stats": [{"ConnIDs": ["*internal"]}],
    	"*resources": [{"ConnIDs": ["*internal"]}],
    	"*accounts": [{"ConnIDs": ["*internal"]}]
    },
  },

  "configDB": {
    "dbType": "mongo",
    "dbName": "16",
    "dbPort": 27017,
  },

  "loaders": [
    {
      "id": "*default",
      "enabled": true,
      "tenant": "cgrates.org",
      "lockfilePath": ".cgr.lck",
      "tpInPath": "/usr/share/cgrates/tariffplans/testit",
      "tpOutPath": ""
    }
  ]
}
