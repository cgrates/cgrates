{
// CGRateS Configuration file
//


"general": {
  "replyTimeout": "50s",
  "cachingDelay": "1s",
},

"logger": {
	"level": 7
},

"listen": {
  "rpcJSON": ":2012",
  "rpcGOB": ":2013",
  "http": ":2080",
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
  "enabled": true,
  "conns": {
  	"*chargers": [{"ConnIDs": ["*internal"]}]
  },
},


"attributes": {
  "enabled": true,
  "conns": {
  	"*stats": [{"ConnIDs": ["*localhost"]}],
  	"*resources": [{"ConnIDs": ["*localhost"]}],
  	"*accounts": [{"ConnIDs": ["*localhost"]}]
  },
},


"chargers": {
  "enabled": true,
  "conns": {
  	"*attributes": [{"ConnIDs": ["*internal"]}]
  },
},


"resources": {
  "enabled": true,
  "storeInterval": "1s",
  "conns": {
  	"*thresholds": [{"ConnIDs": ["*internal"]}]
  },
},


"stats": {
  "enabled": true,
  "storeInterval": "1s",
  "conns": {
  	"*thresholds": [{"ConnIDs": ["*internal"]}]
  },
},


"thresholds": {
  "enabled": true,
  "storeInterval": "1s",
},


"routes": {
  "enabled": true,
  "prefixIndexedFields":["*req.Destination"],
  "conns": {
  	"*stats": [{"ConnIDs": ["*internal"]}],
  	"*resources": [{"ConnIDs": ["*internal"]}],
  	"*rates": [{"ConnIDs": ["*internal"]}]
  },
},


"sessions": {
  "enabled": true,
  "conns":{
  "*routes": [
     {
      "Tenant": "",
      "FilterIDs": [],
      "ConnIDs": ["*internal"]
     }
  ],
  "*resources": [
     {
      "Tenant": "",
      "FilterIDs": [],
      "ConnIDs": ["*internal"]
     }
  ],
  "*attributes": [
     {
      "Tenant": "",
      "FilterIDs": [],
      "ConnIDs": ["*internal"]
     }
  ],
  "*cdrs": [
     {
      "Tenant": "",
      "FilterIDs": [],
      "ConnIDs": ["*internal"]
     }
  ],
  "*chargers": [
     {
      "Tenant": "",
      "FilterIDs": [],
      "ConnIDs": ["*internal"]
     }
  ]
      },
},


"migrator":{

  "usersFilters":["Account"],
},


"admins": {
  "enabled": true,
},


"rates": {
  "enabled": false
},


"actions": {
  "enabled": true,
  "conns": {
  	"*accounts": [{"ConnIDs": ["*localhost"]}]
  },
},


"accounts": {
  "enabled": true
},


"filters": {
  "conns": {
  	"*stats": [{"ConnIDs": ["*internal"]}],
  	"*resources": [{"ConnIDs": ["*internal"]}],
  	"*accounts": [{"ConnIDs": ["*internal"]}]
  },
},

"configDB": {
  "dbType": "redis",
  "dbPort": 6379,
  "dbName": "12"
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": ".cgr.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/testit",
		"tpOutPath": ""
	}
]

}
