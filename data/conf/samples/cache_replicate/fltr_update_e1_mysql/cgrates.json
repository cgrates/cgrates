{
    // CGRateS Configuration file
    // Used in apis/filter_update_it_test.go
    
    
    "general": {
        "nodeID": "fltr_update_e1_mysql",
    },
    
    "logger": {
        "level": 7
    },
    
    "listen": {
        "rpc_json": ":22012",
        "rpc_gob": ":22013",
        "http": ":22080",
    },
    
    "db": {
        "dbConns": {
            "*default": {
                "dbType": "redis",
                "dbHost": "127.0.0.1",
                "dbPort": 6379,
                "dbName": "10",
                "dbUser": "cgrates"
            },
            "StorDB": {
                "dbType": "mysql",
                "dbHost": "127.0.0.1",
                "dbPort": 3306,
                "dbName": "cgrates",
                "dbUser": "cgrates",
                "dbPassword": "CGRateS.org"
            }
        },
        "items": {
            "*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
        }
    },
    
    "rpcConns": {
        "cache_conn": {
            "strategy": "*broadcast_sync",
            "conns": [{"address": "127.0.0.1:22012", "transport":"*json"},{"address": "127.0.0.1:2012", "transport": "*json"}],
        },
    },
    
    "attributes": {
        "enabled": true
    },
    
    "admins": {
        "enabled": true,
        "conns": {
        	"*caches": [{"ConnIDs": ["cache_conn"]}]
        },
    },
    
}