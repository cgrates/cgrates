{
// CGRateS Configuration file
//
// Used in apier_local_tests
// Starts rater, cdrs and mediator connecting over internal channel

"listen": {
	"rpcJSON": "127.0.0.1:12012",			// RPC JSON listening address
	"rpcGOB": "127.0.0.1:12013",			// RPC GOB listening address
	"http": "127.0.0.1:12080",				// HTTP listening address
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
	"enabled": true,						// start the CDR Server service:  <true|false>
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},

"chargers": {
	"enabled": true,
},

"rates": {
	"enabled": true,
},


"admins": {
	"enabled": true,
},


}