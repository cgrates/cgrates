{
// CGRateS Configuration file
//
// Used in general_tests

"general": {
    "posterAttempts": 1,
	"failedPostsTTL": "1",
},

"logger": {
	"level": 7
},

"db":{
	"dbConns": {
		"*default": {
			"dbType": "*internal",
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		},
	}
},


"attributes": {								
	"enabled": true,
},

"chargers":{
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"ees": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
	"exporters": [
		{
			"id": "amqp_test_file",
			"type": "*amqpJSONMap",
			"exportPath": "amqps://guest:guest@localhost:256733/",
			"attempts": 1,
			"synchronous": true,
			"fields":[
				{"tag": "*originID", "path": "*exp.*originID", "type": "*variable", "value": "~*opts.*originID"},
			],
		}
	]
},



"stats": {									
	"enabled": true,
	"storeInterval": "-1",
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1",
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*rates": [{"ConnIDs": ["*internal"]}],
		"*attributes": [{"ConnIDs": ["*internal"]}],
		"*chargers": [{"ConnIDs": ["*internal"]}],
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*thresholds": [{"ConnIDs": ["*internal"]}],
		"*ees": [{"ConnIDs": ["*localhost"]}]
	},
	"onlineCDRExports": ["amqp_test_file"],
},


"admins": {
	"enabled": true,
},

"caches":{
	"partitions": {
		"*rpcResponses": {"limit": -1, "ttl": "2s", "staticTTL": false}
	},
},

}
