{
// CGRateS Configuration file
//
// Used in general_tests

"general": {
    "posterAttempts": 1,
	"failedPostsTTL": "1",
},

"logger": {
	"level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"attributes": {								
	"enabled": true,
},

"chargers":{
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"ees": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
	"exporters": [
		{
			"id": "amqp_test_file",
			"type": "*amqpJSONMap",
			"exportPath": "amqps://guest:guest@localhost:256733/",
			"attempts": 1,
			"synchronous": true,
			"fields":[
				{"tag": "*originID", "path": "*exp.*originID", "type": "*variable", "value": "~*opts.*originID"},
			],
		}
	]
},


"stats": {									
	"enabled": true,
	"storeInterval": "-1",
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1",
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*rates": [{"connIDs": ["*internal"]}],
		"*attributes": [{"connIDs": ["*internal"]}],
		"*chargers": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}],
		"*thresholds": [{"connIDs": ["*internal"]}],
		"*ees": [{"connIDs": ["*localhost"]}]
	},
	"onlineCDRExports": ["amqp_test_file"],
},


"admins": {
	"enabled": true,
},

"caches":{
	"partitions": {
		"*rpcResponses": {"limit": -1, "ttl": "2s", "staticTTL": false}
	},
},

}
