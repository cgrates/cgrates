{

"logger": {
	"level": 7                                                 
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "*internal",
			"string_indexed_fields": ["*opts.*accounts"],
			"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		},
	}
},

"rates": {
	"enabled": true
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}],
		"*chargers": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*localhost"]}],
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*thresholds": [{"ConnIDs": ["*localhost"]}]
	},
},

"attributes": {
	"enabled": true
},

"stats": {
	"enabled": true,
	"store_interval": "-1",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"conns": {
		"*actions": [{"ConnIDs": ["*localhost"]}]
	},
	"store_interval": "-1"
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*localhost"]}]
	},
},

"admins": {
	"enabled": true,
},

"actions": {
	"enabled": true
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfile_path": ".cgr.lck",
		"tp_in_dir": "/usr/share/cgrates/tariffplans/testit",
		"tp_out_dir": ""
	}
]

}
