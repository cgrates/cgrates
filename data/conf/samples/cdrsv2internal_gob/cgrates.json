{
	"logger": {
		"level": 7
	},


	"rpcConns": {
		"conn1": {
			"strategy": "*first",
			"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}]
		}
	},

	"rates": {
		"enabled": true
	},

	"cdrs": {
		"enabled": true,
		"conns": {
			"*attributes": [{"connIDs": ["*internal"]}],
			"*chargers": [{"connIDs": ["conn1"]}],
			"*rates": [{"connIDs": ["conn1"]}],
			"*stats": [{"connIDs": ["conn1"]}],
			"*thresholds": [{"connIDs": ["conn1"]}]
		},
	},

	"attributes": {
		"enabled": true
	},

	"stats": {
		"enabled": true,
		"storeInterval": "1s",
		"conns": {
			"*thresholds": [{"connIDs": ["*internal"]}]
		},
	},

	"thresholds": {
		"enabled": true,
		"conns": {
			"*actions": [{"connIDs": ["*localhost"]}]
		},
		"storeInterval": "1s"
	},

	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"connIDs": ["*internal"]}]
		},
	},

	"admins": {
		"enabled": true,
	},

	"actions": {
		"enabled": true
	},

	"loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfilePath": ".cgr.lck",
			"tpInPath": "/usr/share/cgrates/tariffplans/testit",
			"tpOutPath": ""
		}
	]

}
