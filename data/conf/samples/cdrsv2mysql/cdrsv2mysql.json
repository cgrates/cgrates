{

"logger": {
	"level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}],
		"*chargers": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*localhost"]}],
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*thresholds": [{"ConnIDs": ["*localhost"]}]
	},
},

"attributes": {
	"enabled": true
},

"stats": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"conns": {
		"*actions": [{"ConnIDs": ["*localhost"]}]
	},
	"store_interval": "1s"
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"admins": {
	"enabled": true,
},

"actions": {
	"enabled": true
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfile_path": ".cgr.lck",
		"tp_in_path": "/usr/share/cgrates/tariffplans/testit",
		"tp_out_path": ""
	}
]

}
