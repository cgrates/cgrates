{
	"logger": {
		"level": 7
	},


	"rpc_conns": {
		"conn1": {
			"strategy": "*first",
			"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}]
		}
	},

	"rates": {
		"enabled": true
	},

	"schedulers": {
		"enabled": true,
	},

	"cdrs": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*internal"]}],
			"*chargers": [{"ConnIDs": ["conn1"]}],
			"*rates": [{"ConnIDs": ["conn1"]}],
			"*stats": [{"ConnIDs": ["conn1"]}],
			"*thresholds": [{"ConnIDs": ["conn1"]}]
		},
		"scheduler_conns": ["*localhost"]
	},

	"attributes": {
		"enabled": true
	},

	"stats": {
		"enabled": true,
		"store_interval": "1s",
		"conns": {
			"*thresholds": [{"ConnIDs": ["*internal"]}]
		},
	},

	"thresholds": {
		"enabled": true,
		"conns": {
			"*actions": [{"ConnIDs": ["*localhost"]}]
		},
		"store_interval": "1s"
	},

	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*internal"]}]
		},
	},

	"admins": {
		"enabled": true,
	},

	"actions": {
		"enabled": true
	},

	"loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfile_path": ".cgr.lck",
			"tp_in_dir": "/usr/share/cgrates/tariffplans/testit",
			"tp_out_dir": ""
		}
	]
}
