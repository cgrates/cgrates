{
// CGRateS Configuration file
//
// Used in apier_local_tests
// Starts rater, cdrs and mediator connecting over internal channel

"logger": {
	"level": 7
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}],
		"*chargers": [{"connIDs": ["*localhost"]}],
		"*rates": [{"connIDs": ["*localhost"]}],
		"*stats": [{"connIDs": ["*localhost"]}],
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},

"attributes": {
	"enabled": true,
},

"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"admins": {
	"enabled": true,
},

}
