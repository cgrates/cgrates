{

"logger": {
	"level": 7                                                 
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",	// db type: <internal|redis|mysql|mongo|postgres>
			"dbHost": "127.0.0.1",
			"dbPort": 6379, 	// db port to reach the database
			"dbName": "10", 	// db database name to connect to
			"stringIndexedFields": ["*opts.*accounts"]
		},
	}
},

"rates": {
	"enabled": true
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}],
		"*chargers": [{"connIDs": ["*localhost"]}],
		"*rates": [{"connIDs": ["*localhost"]}],
		"*stats": [{"connIDs": ["*localhost"]}],
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},

"attributes": {
	"enabled": true
},

"stats": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"conns": {
		"*actions": [{"connIDs": ["*localhost"]}]
	},
	"storeInterval": "-1"
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*localhost"]}]
	},
},

"admins": {
	"enabled": true,
},

"actions": {
	"enabled": true
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": ".cgr.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/testit",
		"tpOutPath": ""
	}
]

}
