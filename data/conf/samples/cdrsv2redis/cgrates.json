{

"logger": {
	"level": 7                                                 
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "redis",	// db type: <internal|redis|mysql|mongo|postgres>
			"db_host": "127.0.0.1",
			"db_port": 6379, 	// db port to reach the database
			"db_name": "10", 	// db database name to connect to
			"string_indexed_fields": ["*opts.*accounts"]
		},
	}
},

"rates": {
	"enabled": true
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*attributes": [{"Values": ["*internal"]}],
		"*chargers": [{"Values": ["*localhost"]}],
		"*rates": [{"Values": ["*localhost"]}],
		"*stats": [{"Values": ["*localhost"]}],
		"*thresholds": [{"Values": ["*localhost"]}]
	},
},

"attributes": {
	"enabled": true
},

"stats": {
	"enabled": true,
	"store_interval": "-1",
	"conns": {
		"*thresholds": [{"Values": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"conns": {
		"*actions": [{"Values": ["*localhost"]}]
	},
	"store_interval": "-1"
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"Values": ["*localhost"]}]
	},
},

"admins": {
	"enabled": true,
},

"actions": {
	"enabled": true
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfile_path": ".cgr.lck",
		"tp_in_dir": "/usr/share/cgrates/tariffplans/testit",
		"tp_out_dir": ""
	}
]

}
