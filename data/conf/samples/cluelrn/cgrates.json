{
// CGRateS Configuration file
//


"logger": {
	"level": 7
},


"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"dbConns": {
		"*default": {
			"dbType": "redis",						// data_db type: <redis|mongo>
			"dbPort": 6379, 						// data_db port to reach the database
			"dbName": "10", 						// data_db database name to connect to
		},
	},
},


"cdrs": {
	"enabled": true,
},


"attributes": {
	"enabled": true,
	"opts":{
		"*processRuns": {
			"": 5,
		},                     
	},
},


"routes": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*localhost"]}]
	},
},


"admins": {
	"enabled": true,
},

}
