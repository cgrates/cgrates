{
  "general": {
    "node_id": "SyWithBackup",
    "log_level": 7
  },
  "schedulers": {
    "enabled": true
  },
  "listen": {
    "rpc_json": ":2012",
    "rpc_gob": ":2013",
    "http": ":2080"
  },
  "apiers": {
    "enabled": true,
    "scheduler_conns": ["*localhost"]
  },
  "filters": {
    "apiers_conns": ["*localhost"]
  },
  "thresholds": {
    "enabled": true
  },
  "rpc_conns": {
    "*bijson_localhost_thresholds": {
      "conns": [
        {
          "address": "127.0.0.1:2014",
          "transport": "*birpc_json"
        }
      ]
    }
  },
  "sessions": {
    "enabled": true,
    "apiers_conns": ["*localhost"],
    "thresholds_conns": ["*birpc_internal"],
    "chargers_conns": ["*localhost"],
    "rals_conns": ["*localhost"],
    "backup_interval": "-1"
  },
  "chargers": {
    "enabled": true,
    "string_indexed_fields": ["*req.Account"]
  },
  "rals": {
    "enabled": true,
    "thresholds_conns": ["*localhost"],
    "max_computed_usage": {
      "*data": "10737418"
    }
  },
  "diameter_agent": {
    "enabled": true,
    "listeners": [
      {
        "address": "0.0.0.0:3868"
      }
    ],
    "sessions_conns": ["*bijson_localhost"],
    "snr_template": "*snr",
