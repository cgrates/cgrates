{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"defaultTenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"rpcConns": {
	"*jsonbirpc": {
		"conns": [{"address": "127.0.0.1:2014", "transport":"*birpc_json"}],
	},
},				

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",	
			"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		},
	},
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"rates": {
	"enabled": true,
},


"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	]
			},
},

"diameterAgent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"connIDs": ["*jsonbirpc"]}]
	},
	"asrTemplate": "*asr",
	"rarTemplate": "*rar",
	"forcedDisconnect": "*asr",								// the request to send to diameter on DisconnectSession <*none|*asr|*rar>
},

"admins": {
	"enabled": true,
},

}
