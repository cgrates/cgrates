{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"defaultTenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"dbConns": {
		"*default": {
			"dbType": "mongo",					// stor database type to use: <mysql|postgres>
			"dbPort": 27017, 						// the port to reach the datadb
			"dbName": "datadb",
			"dbPassword": "",
		},
	},
},


"rpcConns": {
	"*gobbirpc": {
		"conns": [{"address": "127.0.0.1:2015", "transport":"*birpc_gob"}],
	},
},				

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"rates": {
	"enabled": true,
},

"sessions": {
	"enabled": true,
	"listenBiGob": "127.0.0.1:2015",
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	]
			},
},

"diameterAgent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"connIDs": ["*gobbirpc"]}]
	},
	"asrTemplate": "*asr",
	"rarTemplate": "*rar",
	"forcedDisconnect": "*asr",								// the request to send to diameter on DisconnectSession <*none|*asr|*rar>
},

"admins": {
	"enabled": true,
},

}
