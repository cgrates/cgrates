{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"default_tenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpc_json": ":2012",				// RPC JSON listening address
	"rpc_gob": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"db_conns": {
		"*default": {
			"db_type": "mongo",					// stor database type to use: <mysql|postgres>
			"db_port": 27017, 						// the port to reach the datadb
			"db_name": "datadb",
			"db_password": "",
		},
	},
},


"rpc_conns": {
	"*gobbirpc": {
		"conns": [{"address": "127.0.0.1:2015", "transport":"*birpc_gob"}],
	},
},				

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"rates": {
	"enabled": true,
},

"sessions": {
	"enabled": true,
	"listen_bigob": "127.0.0.1:2015",
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	]
			},
},

"diameter_agent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"ConnIDs": ["*gobbirpc"]}]
	},
	"asr_template": "*asr",
	"rar_template": "*rar",
	"forced_disconnect": "*asr",								// the request to send to diameter on DisconnectSession <*none|*asr|*rar>
},

"admins": {
	"enabled": true,
},

}
