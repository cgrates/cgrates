{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"default_tenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpc_json": ":2012",				// RPC JSON listening address
	"rpc_gob": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"db_conns": {
		"*default": {
			"db_type": "redis",						// data_db type: <redis|mongo>
			"db_port": 6379, 						// data_db port to reach the database
			"db_name": "10", 						// data_db database name to connect to
		},
	},
},



"rpc_conns": {
	"*gobbirpc": {
		"conns": [{"address": "127.0.0.1:2015", "transport":"*birpc_gob"}],
	},
},	

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"listen_bigob": "127.0.0.1:2015",
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	]
			},
},

"diameter_agent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"ConnIDs": ["*gobbirpc"]}]
	},
	"asr_template": "*asr",
	"rar_template": "*rar",
	"forced_disconnect": "*asr",								// the request to send to diameter on DisconnectSession <*none|*asr|*rar>
},

"admins": {
	"enabled": true,
},

}
