{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"defaultTenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",	
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		},
	}
},

"rates": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	]
			},
},

"diameterAgent": {
	"enabled": true,
	"listeners": [
		{
			"address": "127.0.0.1:3869",			// address where to listen for diameter requests <x.y.z.y:1234>
			"network": "sctp"				// transport type for diameter <tcp|sctp>
		}
	],
	"conns": {
		"*sessions": [{"connIDs": ["*birpc_internal"]}]
	},
	"rarTemplate": "*rar",
},

"admins": {
	"enabled": true,
},

}
