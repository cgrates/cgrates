{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"defaultTenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	]
			},
},

"diameter_agent": {
	"enabled": true,
	"listen_net":"sctp",
	"listen": "127.0.0.1:3869",									// address where to listen for diameter requests <x.y.z.y:1234>
	"conns": {
		"*sessions": [{"ConnIDs": ["*birpc_internal"]}]
	},
	"rar_template": "*rar",
},

"admins": {
	"enabled": true,
},

}
