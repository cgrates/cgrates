{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler

"general": {
	"default_tenant": "cgrates.com",
},

"logger": {
    "level": 7
},

"listen": {
	"rpc_json": ":2012",				// RPC JSON listening address
	"rpc_gob": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "redis",
			"db_host": "127.0.0.1",
			"db_port": 6379,
			"db_name": "10",
			"db_user": "cgrates"
		},
		"StorDB": {
			"db_type": "mysql",
			"db_host": "127.0.0.1",
			"db_port": 3306,
			"db_name": "cgrates",
			"db_user": "cgrates",
			"db_password": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"Values": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*localhost"]
		 }
	]
			},
},

"diameter_agent": {
	"enabled": true,
	"listen_net":"sctp",
	"listen": "127.0.0.1:3869",									// address where to listen for diameter requests <x.y.z.y:1234>
	"conns": {
		"*sessions": [{"Values": ["*birpc_internal"]}]
	},
	"rar_template": "*rar",
},

"admins": {
	"enabled": true,
},

}
