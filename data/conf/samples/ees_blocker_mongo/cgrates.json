{

    "logger": {
        "level": 7
    },
    
    "listen": {
        "rpc_json": ":2012",
        "rpc_gob": ":2013",
        "http": ":2080"
    },
    
    "db": {
        "dbConns": {
            "*default": {
                "dbType": "mongo",
                "dbHost": "127.0.0.1",	
                "dbPort": 27017,
                "dbName": "10",
                "dbUser": "cgrates"
            },
            "StorDB": {
                "dbType": "mongo",
                "dbHost": "127.0.0.1",	
                "dbPort": 27017,
                "dbName": "cgrates",
                "dbUser": "cgrates"
            }
        },
        "items": {
            "*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
        }
    },
    
    "ees": {
        "enabled": true,
        "cache": {
            "*fileCSV": {"limit": -1, "ttl": "500ms", "staticTTL": false}
        },
        "exporters": [
            {
                "id": "CSVExporter1",
                "type": "*fileCSV",
                "export_path": "/tmp/CSVFile1",
                "attempts": 1,
                "blocker": true,
                "field_separator": ","
            },
            {
                "id": "CSVExporter2",
                "type": "*fileCSV",
                "export_path": "/tmp/CSVFile2",
                "attempts": 1,
                "field_separator": ","
            }
        ]
    },
    
    
    "admins": {
        "enabled": true
    }
    
}