{
// CGRateS Configuration file
//
// Used for SessionSv1 integration tests


"logger": {
    "level": 7
},


"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",	
				"opts":{
			"internalDBRewriteInterval": "0s",
			"internalDBDumpInterval": "0s"
		}
		},
	},
},

"rates": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "-1",
},


"attributes": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
