{
// CGRateS Configuration file
//
// Used for SessionSv1 integration tests


"logger": {
    "level": 7
},


"listen": {
	"rpc_json": ":2012",
	"rpc_gob": ":2013",
	"http": ":2080",
},


"db": {
	"db_conns": {
		"*default": {
			"db_type": "*internal",	
				"opts":{
			"internalDBRewriteInterval": "0s",
			"internalDBDumpInterval": "0s"
		}
		},
	},
},

"rates": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"Values": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"store_interval": "-1",
},


"attributes": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"Values": ["*localhost"]}],
		"*rates": [{"Values": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"Values": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
