{
// CGRateS Configuration file
//
// Used for SessionSv1 integration tests


"logger": {
    "level": 7
},


"listen": {
	"rpc_json": ":2012",
	"rpc_gob": ":2013",
	"http": ":2080",
},


"db": {								
	"db_conns": {
		"*default": {
			"db_type": "redis",						
			"db_port": 6379, 						
			"db_name": "10", 						
		},
		"StorDB": {						 // The id of the DB connection
			"db_type": "postgres",			 // db type: <internal|redis|mysql|mongo|postgres>
			"db_host": "127.0.0.1",	
			"db_port": 5432, 			 // db port to reach the database
			"db_name": "cgrates",		 // the host to connect to
			"db_user": "cgrates",
			"db_password": "CGRateS.org" // password to use when connecting to the database
		},
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
},


"attributes": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
