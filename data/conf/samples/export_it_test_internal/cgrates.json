{
    // CGRateS Configuration file
    //
    
    
    "general": {
        "reply_timeout": "50s"
    },

    "logger": {
        "level": 7
    },
    
    "listen": {
        "rpc_json": ":2012",
        "rpc_gob": ":2013",
        "http": ":2080"
    },
    
    
    "db": {
        "db_conns": {
	    	"*default": {
                "db_type": "*internal",
                	"opts":{
		    "internalDBRewriteInterval": "0s",
		    "internalDBDumpInterval": "0s"
	    }
	        },
	    }
    },
    
    "cdrs": {
        "enabled": true,
        "conns": {
        	"*chargers": [{"ConnIDs": ["*internal"]}]
        },
    },

    "tpes": {
        "enabled": true,
    },

    
    "attributes": {
        "enabled": true,
        "conns": {
        	"*stats": [{"ConnIDs": ["*localhost"]}],
        	"*resources": [{"ConnIDs": ["*localhost"]}],
        	"*accounts": [{"ConnIDs": ["*localhost"]}]
        },
    },
    
    
    "chargers": {
        "enabled": true,
        "conns": {
        	"*attributes": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "resources": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "stats": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    "thresholds": {
        "enabled": true,
        "store_interval": "-1"
    },
    
    
    "routes": {
        "enabled": true,
        "prefix_indexed_fields":["*req.Destination"],
        "conns": {
        	"*stats": [{"ConnIDs": ["*internal"]}],
        	"*resources": [{"ConnIDs": ["*internal"]}],
        	"*rates": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "sessions": {
        "enabled": true,
        "conns":{
        "*routes": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*resources": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*attributes": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*rates": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*cdrs": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*chargers": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ]
                        },
    },
    
    
    "admins": {
        "enabled": true,

    },
    
    
    "rates": {
        "enabled": true
    },
    
    
    "actions": {
        "enabled": true,
        "conns": {
        	"*accounts": [{"ConnIDs": ["*localhost"]}]
        },
    },
    
    
    "accounts": {
        "enabled": true
    },
    
    
    "filters": {
        "conns": {
        	"*stats": [{"ConnIDs": ["*internal"]}],
        	"*resources": [{"ConnIDs": ["*internal"]}],
        	"*accounts": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    "loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfile_path": ".cgr.lck",
			"tp_in_dir": "/usr/share/cgrates/tariffplans/loadRateTest",
			"tp_out_dir": "",
		},
	],
	

    }
    