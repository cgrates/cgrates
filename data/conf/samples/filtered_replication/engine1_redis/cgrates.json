{

"general": {
	"nodeID" : "EngineMongo1"
},

"logger": {
    "level": 7
},

"listen": {
	"rpc_json": ":2022",
	"rpc_gob": ":2023",
	"http": ":2280"
},

"rpcConns": {
	"conn1": {
		"strategy": "*first",
		"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}]
	}
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbPort": 6379,
			"dbName": "10",
			"remoteConns": ["conn1"],
			"remoteConnID": "engine1",
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*accounts":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*resource_profiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*resources":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*statqueue_profiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*statqueues": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*threshold_profiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*thresholds": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*filters": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*route_profiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*attribute_profiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*charger_profiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*rate_profiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*load_ids":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*action_profiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"admins": {
	"enabled": true
},

"thresholds": {
	"enabled": true
},

"stats": {
	"enabled": true
},

"resources": {
	"enabled": true
}

}
