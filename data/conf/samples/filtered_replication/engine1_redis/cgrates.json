{

"general": {
	"nodeID" : "EngineMongo1"
},

"logger": {
    "level": 7
},

"listen": {
	"rpcJSON": ":2022",
	"rpcGOB": ":2023",
	"http": ":2280"
},

"rpcConns": {
	"conn1": {
		"strategy": "*first",
		"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}]
	}
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbPort": 6379,
			"dbName": "10",
			"remoteConns": ["conn1"],
			"remoteConnID": "engine1",
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*accounts":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*resourceProfiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*resources":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*statQueueProfiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*statQueues": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*thresholdProfiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*thresholds": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*filters": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*routeProfiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*attributeProfiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*chargerProfiles": {"remote":true,"replicate":false, "dbConn": "*default"},
		"*rateProfiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*loadIDs":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*actionProfiles":{"remote":true,"replicate":false, "dbConn": "*default"},
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"admins": {
	"enabled": true
},

"thresholds": {
	"enabled": true
},

"stats": {
	"enabled": true
},

"resources": {
	"enabled": true
}

}
