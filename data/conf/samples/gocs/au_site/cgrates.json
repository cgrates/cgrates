{

  "general": {
    "nodeID": "AU_SITE",
  },

  "logger": {
    "level": 7
},

  "listen": {
    "rpc_json": ":3012",
    "rpc_gob": ":3013",
    "http": ":3080",
  },


  "rpcConns": {
    "conn1": {
      "strategy": "*first",
      "conns": [{"address": "127.0.0.1:3012", "transport":"*json"}],
    },
    "rmtConn": {
      "strategy": "*first",
      "conns": [{"address": "127.0.0.1:4013", "transport":"*gob"}],
    },
    "*internal": {
      "strategy": "*first",
      "conns": [{"address": "*internal"}],
    }
  },


  "db": {
    "dbConns": {
		  "*default": {
        "dbType": "*internal",
        "remoteConns": ["rmtConn"],
        "opts":{
		      "internalDBRewriteInterval": "0s",
		       "internalDBDumpInterval": "0s"
	    }
	    },
      "StorDB": {						
			  "dbType": "mysql",			 
			  "dbHost": "127.0.0.1",		
			  "dbPort": 3306, 			
			  "dbName": "cgrates", 	
			  "dbUser": "cgrates", 		
			  "dbPassword": "CGRateS.org" 
		  },
	  },
    "items":{
      "*accounts":{"remote":true, "dbConn": "*default"},
      "*filters": {"remote":true, "dbConn": "*default"},
      "*routeProfiles":{"remote":true, "dbConn": "*default"},
      "*attributeProfiles":{"remote":true, "dbConn": "*default"},
      "*chargerProfiles": {"remote":true, "dbConn": "*default"},
      "*loadIds":{"remote":true, "dbConn": "*default"},
      "*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
    }
  },

  "rates": {
    "enabled": true,
  },


  "chargers": {
    "enabled": true,
  },

  "sessions": {
    "enabled": true,
    "conns":{
    "*rates": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*chargers": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ]
            },
  },

  "admins": {
    "enabled": true,
    "conns": {
    	"*caches": [{"ConnIDs": ["conn1"]}]
    },
  }
}
