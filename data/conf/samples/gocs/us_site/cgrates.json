{
  "general": {
    "nodeID": "US_SITE"
  },

  "logger": {
    "level": 7
  },

  "listen": {
    "rpcJSON": ":4012",
    "rpcGOB": ":4013",
    "http": ":4080"
  },

  "rpcConns": {
    "conn1": {
      "strategy": "*first",
      "conns": [{"address": "127.0.0.1:4012", "transport":"*json"}]
    },
    "rplConn": {
      "strategy": "*first",
      "conns": [{"address": "127.0.0.1:3013", "transport":"*gob"}]
    },
    "*internal": {
      "strategy": "*first",
      "conns": [{"address": "*internal"}]
    }
  },

  "db": {
    "dbConns": {
      "*default": {
        "dbType": "*redis",
        "dbHost": "127.0.0.1",
        "dbPort": 6379,
        "dbName": "11",
        "dbUser": "cgrates",
        "replicationConns": ["rplConn"]
      },
      "StorDB": {
        "dbType": "mysql",
        "dbHost": "127.0.0.1",
        "dbPort": 3306,
        "dbName": "cgrates",
        "dbUser": "cgrates",
        "dbPassword": "CGRateS.org"
      }
    },
    "items": {
      "*accounts":{"replicate":true, "dbConn": "*default"},
      "*resourceProfiles":{"replicate":false, "dbConn": "*default"},
      "*resources":{"replicate":false, "dbConn": "*default"},
      "*statQueueProfiles": {"replicate":false, "dbConn": "*default"},
      "*statQueues": {"replicate":false, "dbConn": "*default"},
      "*thresholdProfiles": {"replicate":false, "dbConn": "*default"},
      "*thresholds": {"replicate":false, "dbConn": "*default"},
      "*filters": {"replicate":false, "dbConn": "*default"},
      "*routeProfiles":{"replicate":false, "dbConn": "*default"},
      "*attributeProfiles":{"replicate":false, "dbConn": "*default"},
      "*chargerProfiles": {"replicate":false, "dbConn": "*default"},
      "*loadIDs":{"replicate":false, "dbConn": "*default"},
      "*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
    }
  },

  "rates": {
    "enabled": true,
    "max_increments":3000000
  },


  "cdrs": {
    "enabled": true,
    "conns": {
    	"*chargers": [{"ConnIDs": ["conn1"]}],
    	"*rates": [{"ConnIDs": ["*internal"]}]
    },
  },


  "chargers": {
    "enabled": true
  },


  "sessions": {
    "enabled": true,
    "listenBiJSON": ":4014",
    "conns":{
    "*rates": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*cdrs": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ],
    "*chargers": [
         {
            "Tenant": "",
            "FilterIDs": [],
            "ConnIDs": ["*internal"]
         }
    ]
            },
  },


  "admins": {
    "enabled": true,
    "conns": {
    	"*caches": [{"ConnIDs": ["conn1"]}]
    },
  },

  "accounts": {
    "enabled": true
  }

}
