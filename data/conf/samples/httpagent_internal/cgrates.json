{
// CGRateS Configuration file
//


"logger": {
	"level": 7
},


"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},

"db": {							
	"dbConns": {
		"*default": {			
			"dbType": "redis",
			"dbPort": 6379, 
			"dbName": "10" 	
		},
		"StorDB": {						
			"dbType": "internal",
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
