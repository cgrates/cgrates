{
// CGRateS Configuration file
//


"logger": {
	"level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
	"rpcJSONtls":":2022",
	"rpcGOBtls":":2023",
	"httpTLS": "localhost:2280",
},

"tls": {
	"serverCertificate" : "/usr/share/cgrates/tls/server.crt",			// path to server certificate(must conatin server.crt + ca.crt)
	"serverKey":"/usr/share/cgrates/tls/server.key",					// path to server key
	"clientCertificate" : "/usr/share/cgrates/tls/client.crt",			// path to client certificate(must conatin client.crt + ca.crt)
	"clientKey":"/usr/share/cgrates/tls/client.key",					// path to client key
	"caCertificate":"/usr/share/cgrates/tls/ca.crt",
},

"rates": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"conns":{
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
