{

    "general": {
        "reply_timeout": "50s"
    },
    
    
    "logger": {
        "type": "*syslog",        // controls the destination of logs <*syslog|*stdout|*kafka>
        "level": 6,               // system level precision for floats 
    },  
    
    "listen": {
        "rpc_json": ":2012",
        "rpc_gob": ":2013",
        "http": ":2080"
    },
    
    
    "db": {
        "db_conns": {
		    "*default": {
                "db_type": "*internal",
                   "opts":{
            "internalDBRewriteInterval": "0s",
            "internalDBDumpInterval": "0s"
        }
	        },
	    }
    },
    
    "cdrs": {
        "enabled": true,
        "conns": {
        	"*chargers": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    "attributes": {
        "enabled": true,
        "conns": {
        	"*stats": [{"ConnIDs": ["*localhost"]}],
        	"*resources": [{"ConnIDs": ["*localhost"]}],
        	"*accounts": [{"ConnIDs": ["*localhost"]}]
        },
    },
    
    
    "chargers": {
        "enabled": true,
        "conns": {
        	"*attributes": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "resources": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "stats": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    "thresholds": {
        "enabled": true,
        "store_interval": "-1"
    },
    

    
    "routes": {
        "enabled": true,
        "prefix_indexed_fields":["*req.Destination"],
        "conns": {
        	"*stats": [{"ConnIDs": ["*internal"]}],
        	"*resources": [{"ConnIDs": ["*internal"]}],
        	"*rates": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    
    "sessions": {
        "enabled": true,
        "conns":{
        "*rates": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*routes": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*resources": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*attributes": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*cdrs": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ],
        "*chargers": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ]
                        },
    },
    
    
    "admins": {
        "enabled": true
    },
    
    
    "rates": {
        "enabled": true
    },
    
    
    "actions": {
        "enabled": true,
        "conns": {
        	"*accounts": [{"ConnIDs": ["*localhost"]}]
        },
    },
    
    
    "accounts": {
        "enabled": true
    },
    "janus_agent": {
	"enabled": true,
	"url": "/janus",
	"conns": {
		"*sessions": [{"ConnIDs": ["*bijson_localhost"]}]
	},
	"janus_conns": [{
		"address": "localhost:8188",
		"admin_address": "localhost:7188",
		"admin_password": "janusoverlord"
	}]
},
    
    "filters": {
        "conns": {
        	"*stats": [{"ConnIDs": ["*internal"]}],
        	"*resources": [{"ConnIDs": ["*internal"]}],
        	"*accounts": [{"ConnIDs": ["*internal"]}]
        },
    },
    
    "tpes": {
        "enabled": true
    }
    
    }
    