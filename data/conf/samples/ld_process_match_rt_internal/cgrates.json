{
	// CGRateS Configuration file
	//
	
	
	"general": {
		"replyTimeout": "50s",
	},
	
	"logger": {
		"level": 7
	  },
	
	"listen": {
		"rpcJSON": ":2012",
		"rpcGOB": ":2013",
		"http": ":2080",
	},
	
	"db": {
		"dbConns": {
			"*default": {
				"dbType": "*internal",
					"opts":{
					"internalDBRewriteInterval": "0s",
					"internalDBDumpInterval": "0s"
		}
			}
		}
	},

	"loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfilePath": ".cgr.lck",
			"tpInPath": "/usr/share/cgrates/tariffplans/loadRateTest",
			"tpOutPath": "",
		},
	],
	
	"rates": {
		"enabled": true
	},

	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"connIDs": ["*internal"]}],
			"*accounts": [{"connIDs": ["*localhost"]}],
			"*rates": [{"connIDs": ["*localhost"]}],
			"*ees": [{"connIDs": ["conn1"]}]
		},
	},
	
	
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"connIDs": ["*internal"]}]
		},
	},
	
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"connIDs": ["*localhost"]}],
			"*resources": [{"connIDs": ["*localhost"]}],
			"*accounts": [{"connIDs": ["*localhost"]}]
		},
	},

	"accounts": {
		"enabled": true,
		"conns": {
			"*rates": [{"connIDs": ["*internal"]}]
		},
	},

	"rpcConns": {
		"conn1": {
			"strategy": "*first",
			"conns": [{"address": "127.0.0.1:22012", "transport":"*json"}],
		},
	},
	
	}