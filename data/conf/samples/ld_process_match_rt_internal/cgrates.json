{
	// CGRateS Configuration file
	//
	
	
	"general": {
		"reply_timeout": "50s",
	},
	
	"logger": {
		"level": 7
	  },
	
	"listen": {
		"rpc_json": ":2012",
		"rpc_gob": ":2013",
		"http": ":2080",
	},
	
	"db": {
		"db_conns": {
			"*default": {
				"db_type": "*internal",
					"opts":{
					"internalDBRewriteInterval": "0s",
					"internalDBDumpInterval": "0s"
		}
			}
		}
	},

	"loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfile_path": ".cgr.lck",
			"tp_in_dir": "/usr/share/cgrates/tariffplans/loadRateTest",
			"tp_out_dir": "",
		},
	],
	
	"rates": {
		"enabled": true
	},

	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"ConnIDs": ["*internal"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}],
			"*rates": [{"ConnIDs": ["*localhost"]}],
			"*ees": [{"ConnIDs": ["conn1"]}]
		},
	},
	
	
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*internal"]}]
		},
	},
	
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},

	"accounts": {
		"enabled": true,
		"conns": {
			"*rates": [{"ConnIDs": ["*internal"]}]
		},
	},

	"rpc_conns": {
		"conn1": {
			"strategy": "*first",
			"conns": [{"address": "127.0.0.1:22012", "transport":"*json"}],
		},
	},
	
	}