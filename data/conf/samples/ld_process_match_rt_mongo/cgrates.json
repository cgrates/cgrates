{
	// CGRateS Configuration file
	//
	
	
	"general": {
		"replyTimeout": "50s",
	},
	
	"logger": {
		"level": 7
	},
	
	"listen": {
		"rpc_json": ":2012",
		"rpc_gob": ":2013",
		"http": ":2080",
	},
	
	"db": {
		"dbConns": {
			"*default": {
				"dbType": "mongo",
				"dbHost": "127.0.0.1",	
				"dbPort": 27017,
				"dbName": "10",
				"dbUser": "cgrates"
			},
			"StorDB": {
				"dbType": "mongo",
				"dbHost": "127.0.0.1",	
				"dbPort": 27017,
				"dbName": "cgrates",
				"dbUser": "cgrates"
			}
		},
		"items": {
			"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
		}
	},
	
	"loaders": [
		{
			"id": "*default",
			"enabled": true,
			"tenant": "cgrates.org",
			"lockfile_path": ".cgr.lck",
			"tp_in_path": "/usr/share/cgrates/tariffplans/loadRateTest",
			"tp_out_path": "",
		},
	],
	
	"rates": {
		"enabled": true
	},

	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"ConnIDs": ["*internal"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}],
			"*rates": [{"ConnIDs": ["*localhost"]}],
			"*ees": [{"ConnIDs": ["conn1"]}]
		},
	},
	
	
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*internal"]}]
		},
	},
	
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},

	"accounts": {
		"enabled": true,
		"conns": {
			"*rates": [{"ConnIDs": ["*internal"]}]
		},
	},

	"rpcConns": {
		"conn1": {
			"strategy": "*first",
			"conns": [{"address": "127.0.0.1:22012", "transport":"*json"}],
		},
	},
	
	}