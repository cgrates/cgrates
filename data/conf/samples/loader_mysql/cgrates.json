{
// CGRateS Configuration file
//


"general": {
	"replyTimeout": "50s",
},

"logger": {
	"level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},

"rals": {
	"enabled": true,
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
	"max_increments":3000000,
},


"schedulers": {
	"enabled": true,
	"conns": {
		"*cdrs": [{"ConnIDs": ["*internal"]}]
	},
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],
},


