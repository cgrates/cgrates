{
// CGRateS Configuration file


"general": {
	"replyTimeout": "30s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}]
	},
},


"attributes": {							// Attribute service
	"enabled": true,				// starts Attribute service: <true|false>.
},


"loaders": [
	{
		"id": "CustomLoader",								
		"enabled": true,								
		"tenant": "cgrates.org",
		"runDelay": "0",									
		"lockfilePath": ".cgr.lock",					
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": ",",
		"tpInPath": "/tmp/In",
		"tpOutPath": "/tmp/Out",
		"data":[	
			{
				"type": "*attributes",						
				"fileName": "Attributes.csv",				
				"fields": [
					{"tag": "AttributesFields","type": "*template", "value": "attrTemplateLoader"}
				],
			},
		],
	},
	{
		"id": "WithoutMoveToOut",			
		"enabled": true,
		"tenant": "cgrates.org",
		"runDelay": "0",
		"lockfilePath": ".cgr.lock",
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": ",",
		"tpInPath": "/tmp/LoaderIn",
		"tpOutPath": "",
		"data":[
			{
				"type": "*attributes",
				"fileName": "Attributes.csv",
				"fields": [
					{"tag": "AttributesFields","type": "*template", "value": "attrTemplateLoader"}

				],
			},
		],
	},
	{
		"id": "SubpathLoaderWithoutMove",
		"enabled": true,
		"tenant": "cgrates.org",
		"runDelay": "0",
		"lockfilePath": ".cgr.lock",
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": ",",
		"tpInPath": "/tmp/SubpathWithoutMove",
		"tpOutPath": "",
		"data":[
			{
				"type": "*attributes",
				"fileName": "folder1/Attributes.csv",
				"fields": [
					{"tag": "AttributesFields","type": "*template", "value": "attrTemplateLoader"}

				],
			},
		],
	},
	{
		"id": "SubpathLoaderWithMove",
		"enabled": true,
		"tenant": "cgrates.org",
		"runDelay": "0",
		"lockfilePath": ".cgr.lock",
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": ",",
		"tpInPath": "/tmp/SubpathLoaderWithMove",
		"tpOutPath": "/tmp/SubpathOut",
		"data":[
			{
				"type": "*attributes",
				"fileName": "folder1/Attributes.csv",
				"fields": [
					{"tag": "AttributesFields","type": "*template", "value": "attrTemplateLoader"}

				],
			},
		],
	},
	{
		"id": "LoaderWithTemplate",
		"enabled": true,
		"tenant": "cgrates.org",
		"runDelay": "0",
		"lockfilePath": ".cgr.lock",
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": ",",
		"tpInPath": "/tmp/templateLoaderIn",
		"tpOutPath": "/tmp/templateLoaderOut",
		"data":[
			{
				"type": "*attributes",
				"fileName": "Attributes.csv",
				"fields": [
					{"tag": "AttributesFields","type": "*template", "value": "attrTemplateLoader"}
				],
			},
		],
	},
	{
		"id": "CustomSep",								
		"enabled": true,									
		"tenant": "cgrates.org",
		"runDelay": "-1",										
		"lockfilePath": ".cgr.lock",						
		"conns": {
			"*caches": [{"ConnIDs": ["*internal"]}]
		},
		"fieldSeparator": "\t",							
		"tpInPath": "/tmp/customSepLoaderIn",				
		"tpOutPath": "/tmp/customSepLoaderOut",									
		"data":[	
			{
				"type": "*attributes",				
				"fileName": "Attributes",			
				"fields": [
					{"path": "Tenant", "type": "*variable", "value": "cgrates.org", "mandatory": true},
					{"path": "ID", "type": "*variable", "value": "ATTR_;~*req.0", "mandatory": true},
					{"path": "FilterIDs", "type": "*variable", "value": "`*string:~*req.Destination:`;~*req.0"},
					{"path": "Attributes.Path", "type": "*variable", "value": "*req.Destination"},
					{"path": "Attributes.Type", "type": "*variable", "value": "*constant"},
					{"path": "Attributes.Value", "type": "*variable", "value": "~*req.1"},
				],
			},
		],
	}
],


"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",
	"usersFilters":["Account"],
},


"templates": {
	"attrTemplateLoader": [
		{"path": "Tenant", "type": "*variable", "value": "~*req.0", "mandatory": true},
		{"path": "ID", "type": "*variable", "value": "~*req.1", "mandatory": true},
		{"path": "FilterIDs", "type": "*variable", "value": "~*req.2"},
		{"path": "Weights", "type": "*variable", "value": "~*req.3"},
		{"path": "Blockers", "type": "*variable", "value": "~*req.4"},
		{"path": "Attributes.FilterIDs", "type": "*variable", "value": "~*req.5","newBranch":true},
		{"path": "Attributes.Blockers", "type": "*variable", "value": "~*req.6"},
		{"path": "Attributes.Path", "type": "*variable", "value": "~*req.7"},
		{"path": "Attributes.Type", "type": "*variable", "value": "~*req.8"},
		{"path": "Attributes.Value", "type": "*variable", "value": "~*req.9"},
	],
},


"admins": {
	"enabled": true,
},
}
