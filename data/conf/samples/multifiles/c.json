{
// CGRateS Configuration file
// Used in multifile configuration tests
// Should be the third file loaded

"httpAgent": [
	{
		"id": "conecto_xml",
		"url": "/conecto_xml",
		"conns": {
		"*sessions": [{"connIDs": ["*localhost"]}]
			},
		"requestPayload":	"*xml",
		"replyPayload":	"*xml",
		"requestProcessors": [
			{
				"id": "cdr_from_xml",
				"tenant": "cgrates.org",
				"flags": ["*cdrs"],
				"requestFields":[
					{"tag": "ToR", "path": "ToR", "type": "*constant",
					 "value": "*data", "mandatory": true},
				],
				"replyFields":[],
			}
		],
	},
],


}