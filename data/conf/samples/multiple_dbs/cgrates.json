{


"general": {
	"replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080"
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*redis",		
			"dbPort": 6379, 	
			"dbName": "10",
		},
		"intrnl": {
			"dbType": "*internal",
			"opts": {
				"internalDBDumpPath": "/tmp/internal_db/db",
				"internalDBRewriteInterval": "0s"
			}
		},
		"redis2": {
			"dbType": "*redis",		
			"dbPort": 6379, 	
			"dbName": "11"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items":{
		"*chargerProfiles": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "redis2"},
		"*chargerFilterIndexes" : {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate": false, "dbConn": "intrnl"},
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*internal"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s"
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"migrator":{

	"usersFilters":["Account"]
},


"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"]
},


"rates": {
	"enabled": true
},


"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},


"accounts": {
	"enabled": true
},


"filters": {
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"tpes": {
	"enabled": true
},

"loaders": [
	{
		"enabled":true,
		"id": "*default",
		"tpInPath": "/usr/share/cgrates/tariffplans/testit",
		"tpOutPath": "",
		"lockfilePath": ".cgr.lck"
	}
]

}
