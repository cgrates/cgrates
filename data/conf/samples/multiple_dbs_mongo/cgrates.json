{


"general": {
	"reply_timeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": ":2012",
	"rpc_gob": ":2013",
	"http": ":2080"
},

"db": {
	"db_conns": {
		"*default": { // using redis a default to see which files are dumped in internal
			"db_type": "*redis",		
			"db_port": 6379, 	
			"db_name": "10"
		},
		"internalDBConn": {
			"db_type": "*internal",
	     	"opts": {
		      "internalDBDumpPath": "/tmp/internal_db/db",
		    	"internalDBRewriteInterval": "0s"
	}
		},
		"mongoDBConn": {
			"db_type": "mongo",
			"db_host": "127.0.0.1",
			"db_port": 27017,
			"db_name": "cgrates",
			"db_user": "cgrates"
		}
	},
	"items":{
		"*charger_profiles": {"dbConn": "mongoDBConn"},
		"*charger_filter_indexes" : {"dbConn": "internalDBConn"},
		"*cdrs": {"dbConn": "mongoDBConn"}
	}
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*internal"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"store_interval": "1s"
},


"routes": {
	"enabled": true,
	"prefix_indexed_fields":["*req.Destination"],
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"migrator":{

	"users_filters":["Account"]
},


"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"]
},


"rates": {
	"enabled": true
},


"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},


"accounts": {
	"enabled": true
},


"filters": {
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"tpes": {
	"enabled": true
},

"loaders": [
	{
		"enabled":true,
		"id": "*default",
		"tp_in_dir": "/usr/share/cgrates/tariffplans/testit",
		"tp_out_dir": "",
		"lockfile_path": ".cgr.lck"
	}
]

}
