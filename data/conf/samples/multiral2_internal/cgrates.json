		"internalDBDumpInterval": "0s"
	}
    	}
	}
},

"rates": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
},

"sessions": {
	"enabled": true,
},

}
