{
	"general": {
		"nodeID": "offlineWithBackup"
	},
	"logger": {
		"type": "*stdout",
		"level": 7
	},
    "db": {
		"dbConns": {
			"*default": {
				"dbType": "*internal",
				   "opts":{
            	"internalDBStartTimeout": "1m",
            	"internalDBDumpInterval": "500ms",
            	"internalDBRewriteInterval": "-1"
        	}
			}
		},
        "items":{
            "*chargerProfiles": {"limit": -1, "ttl": "1s", "staticTTL": false, "remote":false, "replicate":false}
        }
    },
	"configDB": {
        "dbType": "*internal",
		"opts": {
			"internalDBStartTimeout": "1m",
            "internalDBDumpInterval": "500ms",
            "internalDBRewriteInterval": "-1"
		}
	},
	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"ConnIDs": ["*localhost"]}],
			"*rates": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"resources": {
		"enabled": true,
		"storeInterval": "-1",
		"conns": {
			"*thresholds": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"stats": {
		"enabled": true,
		"storeInterval": "-1",
		"conns": {
			"*thresholds": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"thresholds": {
		"enabled": true,
		"storeInterval": "-1"
	},
	"routes": {
		"enabled": true,
		"prefixIndexedFields": ["*req.Destination"],
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*rates": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"admins": {
		"enabled": true
	},
	"rates": {
		"enabled": true
	},
	"actions": {
		"enabled": true,
		"conns": {
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"accounts": {
		"enabled": true
	},
	"filters": {
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"loaders": [
		{
			"enabled":true,
			"id": "*default",
			"tp_in_path": "/usr/share/cgrates/tariffplans/testit",
			"tp_out_path": "",
			"lockfile_path": ".cgr.lck"
		}
	]
}