{
	"general": {
		"nodeID": "offlineWithBackup"
	},
	"logger": {
		"type": "*stdout",
		"level": 7
	},
    "db": {
		"dbConns": {
			"*default": {
				"dbType": "*internal",
					"opts":{
           	 		"internalDBDumpInterval": "500ms",
            		"internalDBRewriteInterval": "500ms",
        	    	"internalDBFileSizeLimit": "4k"	
        		}
			}
		},
        "items":{
            "*chargerProfiles": {"limit": -1, "ttl": "1s", "staticTTL": false, "remote":false, "replicate":false}
        }
    },
	"configDB": {
        "dbType": "*internal",
		"opts": {
			"internalDBDumpInterval": "500ms",
            "internalDBRewriteInterval": "500ms",
            "internalDBFileSizeLimit": "4k"	
		}
	},
	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"connIDs": ["*localhost"]}],
			"*rates": [{"connIDs": ["*localhost"]}]
		},
	},
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"connIDs": ["*localhost"]}],
			"*resources": [{"connIDs": ["*localhost"]}],
			"*accounts": [{"connIDs": ["*localhost"]}]
		},
	},
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"connIDs": ["*localhost"]}]
		},
	},
	"resources": {
		"enabled": true,
		"storeInterval": "-1",
		"conns": {
			"*thresholds": [{"connIDs": ["*localhost"]}]
		},
	},
	"stats": {
		"enabled": true,
		"storeInterval": "-1",
		"conns": {
			"*thresholds": [{"connIDs": ["*localhost"]}]
		},
	},
	"thresholds": {
		"enabled": true,
		"storeInterval": "-1"
	},
	"routes": {
		"enabled": true,
		"prefixIndexedFields": ["*req.Destination"],
		"conns": {
			"*stats": [{"connIDs": ["*localhost"]}],
			"*resources": [{"connIDs": ["*localhost"]}],
			"*rates": [{"connIDs": ["*localhost"]}]
		},
	},
	"admins": {
		"enabled": true
	},
	"rates": {
		"enabled": true
	},
	"actions": {
		"enabled": true,
		"conns": {
			"*accounts": [{"connIDs": ["*localhost"]}]
		},
	},
	"accounts": {
		"enabled": true
	},
	"filters": {
		"conns": {
			"*stats": [{"connIDs": ["*localhost"]}],
			"*resources": [{"connIDs": ["*localhost"]}],
			"*accounts": [{"connIDs": ["*localhost"]}]
		},
	},
	"loaders": [
		{
			"enabled":true,
			"id": "*default",
			"tpInPath": "/usr/share/cgrates/tariffplans/testit",
			"tpOutPath": "",
			"lockfilePath": ".cgr.lck"
		}
	]
}