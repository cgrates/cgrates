{
	"general": {
		"node_id": "offlineWithBackup"
	},
	"logger": {
		"type": "*stdout",
		"level": 7
	},
    "db": {
		"db_conns": {
			"*default": {
				"db_type": "*internal",
				      "opts":{
            	"internalDBStartTimeout": "1m",
            	"internalDBDumpInterval": "-1",
         	   "internalDBRewriteInterval": "-1"
        }
			}
		},
        "items":{
            "*charger_profiles": {"limit": -1, "ttl": "1s", "static_ttl": false, "remote":false, "replicate":false}
        }
    },
	"config_db": {
        "db_type": "*internal",
		"opts": {
			"internalDBStartTimeout": "1m",
            "internalDBDumpInterval": "-1",
            "internalDBRewriteInterval": "-1"
		}
	},
	"cdrs": {
		"enabled": true,
		"conns": {
			"*chargers": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"attributes": {
		"enabled": true,
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"chargers": {
		"enabled": true,
		"conns": {
			"*attributes": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"resources": {
		"enabled": true,
		"store_interval": "-1",
		"conns": {
			"*thresholds": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"stats": {
		"enabled": true,
		"store_interval": "-1",
		"conns": {
			"*thresholds": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"thresholds": {
		"enabled": true,
		"store_interval": "-1"
	},
	"routes": {
		"enabled": true,
		"prefix_indexed_fields": ["*req.Destination"],
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*rates": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"admins": {
		"enabled": true
	},
	"rates": {
		"enabled": true
	},
	"actions": {
		"enabled": true,
		"conns": {
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"accounts": {
		"enabled": true
	},
	"filters": {
		"conns": {
			"*stats": [{"ConnIDs": ["*localhost"]}],
			"*resources": [{"ConnIDs": ["*localhost"]}],
			"*accounts": [{"ConnIDs": ["*localhost"]}]
		},
	},
	"loaders": [
		{
			"enabled":true,
			"id": "*default",
			"tp_in_dir": "/usr/share/cgrates/tariffplans/testit",
			"tp_out_dir": "",
			"lockfile_path": ".cgr.lck"
		}
	]
}