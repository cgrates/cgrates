{
// CGRateS Configuration file
//

"logger": {
	"level": 7
},


"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rals": {
	"enabled": true,
},

"schedulers": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
	"rals_conns": ["*internal"],
},

"resources": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"routes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
},

"sessions": {
	"enabled": true,
	"debitInterval": "10s",
	"conns":{
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"radiusAgent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"connIDs": ["*localhost"]}]
	},
},



"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"],
},


}
