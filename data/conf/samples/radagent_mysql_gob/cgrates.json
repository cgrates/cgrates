{
// CGRateS Configuration file
//

"logger": {
	"level": 7
},


"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},

"rpcConns": {
	"conn1": {
		"strategy": "*first",
		"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}],
	},
},

"db": {								
	"dbConns": {
		"*default": {
			"dbType": "redis",						
			"dbPort": 6379, 						
			"dbName": "10", 						
		},
	},
},



"rals": {
	"enabled": true,
},

"schedulers": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
	"rals_conns": ["*internal"],
},

"resources": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},

"routes": {
	"enabled": true,
},

"chargers": {
	"enabled": true,
},

"sessions": {
	"enabled": true,
	"debitInterval": "10s",
	"conns":{
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["conn1"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["conn1"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["conn1"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["conn1"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"radiusAgent": {
	"enabled": true,
	"conns": {
		"*sessions": [{"connIDs": ["conn1"]}]
	},
},



"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"],
},


}
