{
  "radiusAgent": {
    "requestProcessors": [
      {
        "id": "DataStart",
        "filters": [
          "*string:~*req.Acct-Status-Type:Start"
        ],
        "flags": [
          "*none",
          "*continue"
        ],
        "requestFields": [],
        "replyFields": []
      },
      {
        "id": "DataStop",
        "filters": [
          "*string:~*req.Acct-Status-Type:Stop"
        ],
        "flags": [
          "*cdrs",
          "*continue"
        ],
        "requestFields": [
          {
            "tag": "Account",
            "path": "*cgreq.Account",
            "type": "*variable",
            "value": "~*req.User-Name",
            "mandatory": true
          },
          {
            "tag": "IMSI",
            "path": "*cgreq.IMSI",
            "type": "*variable",
            "value": "~*req.User-Name",
            "mandatory": true
          },
          {
            "tag": "Country",
            "path": "*cgreq.Country",
            "type": "*variable",
            "value": "~*req.3GPP.3GPP-User-Location-Info{*3gppULI:TAI.MCC.Name}"
          },
          {
            "tag": "OriginID",
            "path": "*opts.*originID",
            "type": "*variable",
            "value": "~*req.Acct-Session-Id",
            "mandatory": true
          },
          {
            "tag": "Usage",
            "path": "*cgreq.Usage",
            "type": "*variable",
            "value": "~*req.Acct-Output-Octets",
            "mandatory": true
          },
          {
            "tag": "DebitUsage",
            "path": "*opts.*usage",
            "type": "*variable",
            "value": "~*req.Acct-Output-Octets",
            "mandatory": true
          }
        ],
        "replyFields": []
      }
    ]
  }
}
