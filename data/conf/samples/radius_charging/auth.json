{
  "radiusAgent": {
    "requestProcessors": [
      {
        "id": "DataAuth",
        "filters": [
          "*string:~*vars.*radReqType:*radAuth"
        ],
        "flags": [
          "*authorize",
          "*accounts",
          "*continue"
        ],
        "requestFields": [
          {
            "tag": "Account",
            "path": "*cgreq.Account",
            "type": "*variable",
            "value": "~*req.User-Name",
            "mandatory": true
          },
          {
            "tag": "IMSI",
            "path": "*cgreq.IMSI",
            "type": "*variable",
            "value": "~*req.User-Name",
            "mandatory": true
          },
          {
            "tag": "Country",
            "path": "*cgreq.Country",
            "type": "*variable",
            "value": "~*req.3GPP.3GPP-User-Location-Info{*3gppULI:TAI.MCC.Name}"
          },
          {
            "tag": "Usage",
            "path": "*opts.*usage",
            "type": "*constant",
            "value": "1024"
          },
          {
            "tag": "OriginID",
            "path": "*opts.*originID",
            "type": "*variable",
            "value": "~*req.Acct-Session-Id",
            "mandatory": true
          }
        ],
        "replyFields": [
          {
            "tag": "Reject",
            "path": "*rep.*radReplyCode",
            "filters": [
              "*notempty:~*cgrep.Error:"
            ],
            "type": "*constant",
            "value": "AccessReject"
          },
          {
            "tag": "RejectMsg",
            "path": "*rep.Reply-Message",
            "filters": [
              "*notempty:~*cgrep.Error:"
            ],
            "type": "*variable",
            "value": "~*cgrep.Error",
            "blocker": true
          },
          {
            "tag": "NoUsageReject",
            "path": "*rep.*radReplyCode",
            "filters": [
              "*eq:~*cgrep.MaxUsage:0"
            ],
            "type": "*constant",
            "value": "AccessReject",
            "blocker": true
          },
          {
            "tag": "Accept",
            "path": "*rep.*radReplyCode",
            "type": "*constant",
            "value": "AccessAccept"
          }
        ]
      }
    ]
  }
}