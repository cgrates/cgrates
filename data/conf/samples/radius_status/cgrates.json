{
  
    "logger": {
        "level": 7
    },
    
    
    "listen": {
        "rpcJSON": ":2012",				// RPC JSON listening address
        "rpcGOB": ":2013",					// RPC GOB listening address
        "http": ":2080",					// HTTP listening address
    },
    
    
    "db": {
        "dbConns": {
            "*default": {
                "dbType": "*internal",
                  "opts":{
            "internalDBRewriteInterval": "0s",
            "internalDBDumpInterval": "0s"
        }
            }
        }
    },
    
    "rals": {
        "enabled": true,
    },
    
    "schedulers": {
        "enabled": true,
    },
    
    "cdrs": {
        "enabled": true,
        "rals_conns": ["*internal"],
    },
    
    "resources": {
        "enabled": true,
        "store_interval": "-1",
    },
    
    "attributes": {
        "enabled": true,
    },
    
    "routes": {
        "enabled": true,
    },
    
    "chargers": {
        "enabled": true,
    },
    
    "sessions": {
        "enabled": true,
        "debitInterval": "10s",
        "conns":{
        "*attributes": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*localhost"]
                 }
        ],
        "*cdrs": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*localhost"]
                 }
        ],
        "*rals": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*localhost"]
                 }
        ],
        "*resources": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*localhost"]
                 }
        ],
        "*chargers": [
                 {
                        "Tenant": "",
                        "FilterIDs": [],
                        "ConnIDs": ["*internal"]
                 }
        ]
                        },
    },
    
    "radiusAgent": {
        "enabled": true,
        "conns": {
        	"*sessions": [{"ConnIDs": ["*bijson_localhost"]}]
        },
        "listeners": [
      {
        "network": "udp",
        "authAddress": "127.0.0.1:1812",
        "acctAddress": "127.0.0.1:1813"
      }
    ],
        "clientDictionaries": {
            "*default": [ "/usr/share/cgrates/radius/dict/"]
        },
        "requestProcessors": [
            {
              "id": "Status",
              "filters": [
                "*string:~*vars.*radReqCode:StatusServer"
              ],
              "flags": [
                "*none","*log",
              ],
              "reply_fields": [
                {
                  "tag": "ReplyMessage",
                  "path": "*rep.Reply-Message",
                  "type": "*constant",
                  "mandatory": true,
                  "value": "OK",
                }
              ]
            }
          ]
    },
    
    
    
    "admins": {
        "enabled": true,
        "scheduler_conns": ["*internal"],
    },
    
    
    }
    