{

"general": {
	"replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": ":2012",
	"rpc_gob": ":2013",
	"http": ":2080"
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
		},
	}
},



"routes": {
	"enabled": true
},

"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"]
}

}