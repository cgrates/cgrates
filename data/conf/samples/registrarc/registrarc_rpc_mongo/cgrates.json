{

"general": {
	"reply_timeout": "30s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": ":3012",
	"rpc_gob": ":3013",
	"http": ":3080"
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "mongo",
			"db_host": "127.0.0.1",	
			"db_port": 27017,
			"db_name": "10",
			"db_user": "cgrates"
		},
		"StorDB": {
			"db_type": "mongo",
			"db_host": "127.0.0.1",	
			"db_port": 27017,
			"db_name": "cgrates",
			"db_user": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rpc_conns": {
	"regConn": {
		"strategy": "*first",
		"conns": [{"address": "http://127.0.0.1:2080/registrar", "transport":"*http_jsonrpc"}]
	}
},

"cdrs": {
	"enabled": true
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"resources": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"stats": {
	"enabled": true,
	"store_interval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"store_interval": "1s"
},

"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*rates": [{"ConnIDs": ["*internal"]}]
	},
},

"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",

	"users_filters":["Account"]
},

"admins": {
	"enabled": true
},

"rates": {
	"enabled": true
},

"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},

"accounts": {
	"enabled": true
},

"filters": {								
	"conns": {
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"registrarc":{
    "rpc":{
        "enabled": true,
        "registrars_conns": ["regConn"],
        "hosts": [
			{
				"Tenant": "*default",
				"ID":"attributes",
				"transport": "*json",
				"tls": false
			}
		],
        "refresh_interval": "1s"
    }
}

}
