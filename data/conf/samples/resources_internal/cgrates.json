{

"logger": {
	"level": 7
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "*internal",
			"opts":{
				"internalDBDumpPath": "/tmp/internal_db/db",
				"internalDBDumpInterval": "-1"
			}
    	}
	}
},

"actions": {
    "enabled": true
},

"thresholds": {
    "enabled": true,
    "conns": {
    	"*actions": [{"Values": ["*internal"]}]
    },
},

"resources": {
  "enabled": true,
  "conns": {
  	"*thresholds": [{"Values": ["*internal"]}]
  },
},

"admins": {
  "enabled": true
}

}