			"dbName": "10",
			"dbUser": "cgrates"
		},
	    "StorDB": {
		    "dbType": "postgres",
			"dbHost": "127.0.0.1",	
			"dbPort": 5432,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
