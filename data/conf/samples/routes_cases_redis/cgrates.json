{
"general": {
    "replyTimeout": "50s"
},

"logger": {
	"level": 7
},
    
"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"attributes": {
    "enabled": true,
    "conns": {
    	"*stats": [{"connIDs": ["*internal"]}],
    	"*resources": [{"connIDs": ["*localhost"]}],
    	"*accounts": [{"connIDs": ["*localhost"]}]
    },
},

"chargers": {
    "enabled": true,
    "conns": {
    	"*attributes": [{"connIDs": ["*internal"]}]
    },
},

"cdrs": {
    "enabled": true
},

