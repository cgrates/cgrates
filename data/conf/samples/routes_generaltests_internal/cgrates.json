
{
"general": {
    "replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
    "rpcJSON": ":2012",
    "rpcGOB": ":2013",
    "http": ":2080"
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",
            	"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
    	}
	}
},

"resources": {
    "enabled": true,
    "storeInterval": "-1",
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}]
    },
},


"stats": {
    "enabled": true,
    "storeInterval": "-1",
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}]
    },
},


"thresholds": {
    "enabled": true,
    "storeInterval": "-1"
},


"routes": {
    "enabled": true,
    "conns": {
    	"*stats": [{"connIDs": ["*internal"]}],
    	"*resources": [{"connIDs": ["*internal"]}],
    	"*rates": [{"connIDs": ["*internal"]}],
    	"*accounts": [{"connIDs": ["*internal"]}]
    },
},

"admins": {
    "enabled": true
},


"rates": {
    "enabled": true
},


"accounts": {
    "enabled": true
},

"loaders": [
    {
        "id": "*default",
        "enabled": true,
        "tenant": "cgrates.org",
        "lockfilePath": ".cgr.lck",
        "tpInPath": "/usr/share/cgrates/tariffplans/testit",
        "tpOutPath": ""
    }
]
    
}