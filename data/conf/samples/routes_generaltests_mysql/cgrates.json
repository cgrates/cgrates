{
"general": {
    "replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
    "rpcJSON": ":2012",
    "rpcGOB": ":2013",
    "http": ":2080"
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"},
		"*routeProfiles": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"resources": {
    "enabled": true,
    "storeInterval": "1s",
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}]
    },
},


"stats": {
    "enabled": true,
    "storeInterval": "1s",
    "conns": {
    	"*thresholds": [{"connIDs": ["*internal"]}]
    },
},

"thresholds": {
    "enabled": true,
    "storeInterval": "1s"
},

"routes": {
    "enabled": true,
    "conns": {
    	"*stats": [{"connIDs": ["*internal"]}],
    	"*resources": [{"connIDs": ["*internal"]}],
    	"*rates": [{"connIDs": ["*internal"]}],
    	"*accounts": [{"connIDs": ["*internal"]}]
    },
},

"admins": {
    "enabled": true
},

"rates": {
    "enabled": true
},

"accounts": {
    "enabled": true
},

"loaders": [
    {
        "id": "*default",
        "enabled": true,
        "tenant": "cgrates.org",
        "lockfilePath": ".cgr.lck",
        "tpInPath": "/usr/share/cgrates/tariffplans/testit",
        "tpOutPath": ""
    }
]
    
}
    