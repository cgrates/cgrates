{
"general": {
    "replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
    "rpc_json": ":2012",
    "rpc_gob": ":2013",
    "http": ":2080"
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {					
			"dbType": "postgres",		
			"dbHost": "127.0.0.1",	
			"dbPort": 5432, 		
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"},
		"*route_profiles": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"resources": {
    "enabled": true,
    "store_interval": "1s",
    "conns": {
    	"*thresholds": [{"ConnIDs": ["*internal"]}]
    },
},


"stats": {
    "enabled": true,
    "store_interval": "1s",
    "conns": {
    	"*thresholds": [{"ConnIDs": ["*internal"]}]
    },
},

"thresholds": {
    "enabled": true,
    "store_interval": "1s"
},

"routes": {
    "enabled": true,
    "conns": {
    	"*stats": [{"ConnIDs": ["*internal"]}],
    	"*resources": [{"ConnIDs": ["*internal"]}],
    	"*rates": [{"ConnIDs": ["*internal"]}],
    	"*accounts": [{"ConnIDs": ["*internal"]}]
    },
},

"admins": {
    "enabled": true
},

"rates": {
    "enabled": true
},

"accounts": {
    "enabled": true
},

"loaders": [
    {
        "id": "*default",
        "enabled": true,
        "tenant": "cgrates.org",
        "lockfile_path": ".cgr.lck",
        "tp_in_path": "/usr/share/cgrates/tariffplans/testit",
        "tp_out_path": ""
    }
]
    
}
    