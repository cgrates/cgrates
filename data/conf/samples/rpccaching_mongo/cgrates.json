			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*accounts": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

