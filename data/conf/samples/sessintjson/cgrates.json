{
// CGRateS Configuration file
//


"general": {
	"replyTimeout": "5m",
},

"logger": {
	"level": 7
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",	
    	}
	},
	"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*localhost"]}]
	},
},


"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*localhost"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1",
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"connIDs": ["*localhost"]}],
		"*resources": [{"connIDs": ["*localhost"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


}
