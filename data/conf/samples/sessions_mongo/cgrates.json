{
// CGRateS Configuration file
//
// Used for SessionSv1 integration tests


"general": {
	"replyTimeout": "10s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"sessionCostRetries": 1,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
},


"attributes": {
	"enabled": true,
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"routes": {
	"enabled": true,
},


"sessions": {
	"enabled": true,
	"sessionTTL": "50ms",
	"alterableFields": ["Extra1"],
	"conns":{
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rates": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


