{

"general": {
	"nodeID":"MasterReplication"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": "127.0.0.1:2012",
	"rpcGOB": "127.0.0.1:2013",
	"http": "127.0.0.1:2080"
},

"rpcConns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22012", "transport": "*json"}]
	}
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
    	}
	}
},



"chargers": {
	"enabled": true
},

"sessions": {
	"enabled": true,		
	"conns":{
	"*replication": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["rplConn"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true
}

}
