{

"general": {
	"nodeID":"MasterReplication"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": "127.0.0.1:2012",
	"rpcGOB": "127.0.0.1:2013",
	"http": "127.0.0.1:2080"
},

"rpcConns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22012", "transport": "*json"}]
	}
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"chargers": {
	"enabled": true
},

"sessions": {
	"enabled": true,		
	"conns":{
	"*replication": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["rplConn"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true
}

}
