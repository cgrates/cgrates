"general": {
	"nodeID":"MasterReplication",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": "127.0.0.1:2012",
	"rpcGOB": "127.0.0.1:2013",
	"http": "127.0.0.1:2080",
},


"rpcConns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22012", "transport": "*json"}],
	},
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbName": "10",
			"dbPort": 27017,
    	}
	}
},




"rals": {
	"enabled": true,
},

"schedulers": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"debitInterval": "5ms",					// interval to perform debits on.
	"conns":{
	"*replication": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["rplConn"]
		 }
	],
	"*rals": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"],
},

}
