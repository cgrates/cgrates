"general": {
	"node_id":"MasterReplication",
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": "127.0.0.1:2012",
	"rpc_gob": "127.0.0.1:2013",
	"http": "127.0.0.1:2080",
},


"rpc_conns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22012", "transport": "*json"}],
	},
},


"db": {
	"db_conns": {
		"*default": {
			"db_type": "mongo",
			"db_name": "10",
			"db_port": 27017,
    	}
	}
},




"rals": {
	"enabled": true,
},

"schedulers": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"debit_interval": "5ms",					// interval to perform debits on.
	"conns":{
	"*replication": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["rplConn"]
		 }
	],
	"*rals": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"],
},

}
