{
// Real-time Online/Offline Charging System (OCS) for Telecom & ISP environments
// Copyright (C) ITsysCOM GmbH
"general": {
	"nodeID":"MasterReplication",
},

"logger": {
	"level": 7
},

"listen": {
	"rpc_json": "127.0.0.1:2012",
	"rpc_gob": "127.0.0.1:2013",
	"http": "127.0.0.1:2080",
},


"rpcConns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22013", "transport": "*gob"}],
	},
},

"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"dbConns": {
		"*default": {
			"dbType": "mongo",					// stor database type to use: <mysql|postgres>
			"dbPort": 27017, 						// the port to reach the datadb
			"dbName": "datadb",
			"dbPassword": "",
    	}
	}
},

"rates": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"conns":{
	"*replication": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["rplConn"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true,
},

}
