"general": {
	"node_id":"MasterReplication",
},

"logger": {
	"level": 7
},

"db": {
	"db_conns": {
		"*default": {
			"db_type": "redis",
			"db_host": "127.0.0.1",
			"db_port": 6379,
			"db_name": "10",
			"db_user": "cgrates"
		},
		"StorDB": {
			"db_type": "mysql",
			"db_host": "127.0.0.1",
			"db_port": 3306,
			"db_name": "cgrates",
			"db_user": "cgrates",
			"db_password": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"listen": {
	"rpc_json": "127.0.0.1:2012",
	"rpc_gob": "127.0.0.1:2013",
	"http": "127.0.0.1:2080",
},


"rpc_conns": {
	"rplConn": {
		"strategy": "*broadcast_sync",
		"conns": [{"address": "127.0.0.1:22012", "transport": "*json"}],
	},
},

"rates": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
},

"attributes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},

"sessions": {
	"enabled": true,
	"conns":{
	"*replication": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["rplConn"]
		 }
	],
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},

"admins": {
	"enabled": true,
},

}
