{
    // CGRateS Configuration file
    // will be used in apis/stats_it_test.go
    "logger": {
      "level": 7
    },

    "db": {
      "dbConns": {
        "*default": {
          "dbType": "redis",
          "dbHost": "127.0.0.1",
          "dbPort": 6379,
          "dbName": "10",
          "dbUser": "cgrates"
        },
        "StorDB": {
          "dbType": "mysql",
          "dbHost": "127.0.0.1",
          "dbPort": 3306,
          "dbName": "cgrates",
          "dbUser": "cgrates",
          "dbPassword": "CGRateS.org"
        }
      },
      "items": {
        "*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
      }
    },

    "listen": {
      "rpcJSON": ":2012",			// RPC JSON listening address
      "rpcGOB": ":2013",			// RPC GOB listening address
      "http": ":2080",				// HTTP listening address
    },
  
    "actions": {
        "enabled": true,
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },

    "stats": {
        "enabled": true,
        "storeInterval": "-1",
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },

    "thresholds": {	
        "enabled": true,
        "storeInterval": "-1",
        "conns": {
        	"*actions": [{"ConnIDs": ["*internal"]}]
        },
    },
  
    "admins": {
      "enabled": true,
    }
  }
