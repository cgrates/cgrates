{
    // CGRateS Configuration file
    // will be used in apis/thresholds_it_test.go
  
    "logger": {
      "level": 7
    },

    "db": {
      "dbConns": {
        "*default": {
          "dbType": "mongo",
          "dbHost": "127.0.0.1",	
          "dbPort": 27017,
          "dbName": "10",
          "dbUser": "cgrates"
        },
        "StorDB": {
          "dbType": "mongo",
          "dbHost": "127.0.0.1",	
          "dbPort": 27017,
          "dbName": "cgrates",
          "dbUser": "cgrates"
        }
      },
      "items": {
        "*cdrs": {"limit": -1, "ttl": "", "static_ttl": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
      }
    },

    "actions": {
        "enabled": true,
        "conns": {
        	"*thresholds": [{"ConnIDs": ["*internal"]}]
        },
    },

    "thresholds": {
        "enabled": true,
        "store_interval": "-1",
        "conns": {
        	"*actions": [{"ConnIDs": ["*internal"]}]
        },
    },
  
    "admins": {
      "enabled": true,
    }
  }