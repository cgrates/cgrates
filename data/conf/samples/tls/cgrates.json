{
// CGRateS Configuration file
//


"logger": {
	"level": 7
},


"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
	"rpcJSONtls":":2022",
	"rpcGOBtls":":2023",
	"httpTLS": ":2280",			
},

"tls": {
	"serverCertificate" : "/usr/share/cgrates/tls/server.crt",			// path to server certificate(must conatin server.crt + ca.crt)
	"serverKey":"/usr/share/cgrates/tls/server.key",					// path to server key
	"clientCertificate" : "/usr/share/cgrates/tls/client.crt",			// path to client certificate(must conatin client.crt + ca.crt)
	"clientKey":"/usr/share/cgrates/tls/client.key",					// path to client key
	"caCertificate":"/usr/share/cgrates/tls/ca.crt",
},


"http": {										// HTTP server configuration
	"jsonRPCurl": "/jsonrpc",					// JSON RPC relative URL ("" to disable)
	"wsURL": "/ws",							// WebSockets relative URL ("" to disable)
	"freeswitchCDRsURL": "/freeswitch_json",	// Freeswitch CDRS relative URL ("" to disable)
	"httpCDRs": "/cdr_http",					// CDRS relative URL ("" to disable)
	"useBasicAuth": false,					// use basic authentication
	"authUsers": {},							// basic authentication usernames and base64-encoded passwords (eg: { "username1": "cGFzc3dvcmQ=", "username2": "cGFzc3dvcmQy "})
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},

"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*localhost"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},

"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*localhost"]
		 }
	]
			},
},

"attributes": {
	"enabled": true,
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}]
	},
},

"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},

}
