{
// CGRateS Configuration file
//


"general": {
	"replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080"
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",
				"opts":{
		"internalDBRewriteInterval": "0s",
		"internalDBDumpInterval": "0s"
	}
    	}
	}
},

"rals": {
	"enabled": true,
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
	"max_increments":3000000
},


"schedulers": {
	"enabled": true,
	"conns": {
		"*cdrs": [{"ConnIDs": ["*internal"]}]
	},
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}]
	},
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"ConnIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"ConnIDs": ["*localhost"]}],
		"*resources": [{"ConnIDs": ["*localhost"]}],
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1"
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"]
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*rals": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
	"scheduler_conns": ["*internal"]
},


"rates": {
	"enabled": true
},


"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"ConnIDs": ["*localhost"]}]
	},
},


"accounts": {
	"enabled": true
},


"filters": {
	"conns": {
		"*stats": [{"ConnIDs": ["*internal"]}],
		"*resources": [{"ConnIDs": ["*internal"]}],
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfile_path": ".cgr.lck",
		"tp_in_path": "/usr/share/cgrates/tariffplans/loadRateTest",
		"tp_out_path": "",
	},
],

}
