{

"general": {
	"replyTimeout": "50s"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080"
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "*internal",	"opts":{
			"internalDBRewriteInterval": "0s",
			"internalDBDumpInterval": "0s"
		}
    	}
	}
},



"rals": {
	"enabled": true,
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
	"max_increments":3000000
},


"schedulers": {
	"enabled": true,
	"conns": {
		"*cdrs": [{"connIDs": ["*internal"]}]
	},
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "-1",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},

"thresholds": {
	"enabled": true,
	"storeInterval": "-1"
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


"filters": {								
	"conns": {
		"*accounts": [{"connIDs": ["*internal"]}]
	},
},

"accounts": {
    "enabled": true
}

}
