{
// CGRateS Configuration file


"general": {
	"replyTimeout": "30s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {		// The id of the DB connection
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {						 // The id of the DB connection
			"dbType": "mongo",			 // db type: <internal|redis|mysql|mongo|postgres>
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,			 // db port to reach the database
			"dbName": "cgrates",		 // the host to connect to
			"dbUser": "cgrates"
		},
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}]
	},
},


"attributes": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*localhost"]}],
		"*resources": [{"connIDs": ["*localhost"]}],
		"*accounts": [{"connIDs": ["*localhost"]}]
	},
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"routes": {
	"enabled": true,
	"prefixIndexedFields":["*req.Destination"],
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"conns":{
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rates": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",

	"usersFilters":["Account"],
},

"admins": {
	"enabled": true,
},


"rates": {
	"enabled": true
},


"actions": {
	"enabled": true,
	"conns": {
		"*accounts": [{"connIDs": ["*localhost"]}]
	},
},


"accounts": {
	"enabled": true
},


"filters": {
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}],
		"*accounts": [{"connIDs": ["*internal"]}]
	},
},

"tpes": {
	"enabled": true
},


}
