{
// CGRateS Configuration file


"general": {
	"replyTimeout": "30s",
},

"logger": {
	"level": 7
},

"rpcConns": {
	"conn1": {
		"strategy": "*first",
		"conns": [{"address": "127.0.0.1:2013", "transport":"*gob"}],
	},
},


"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"db": {
	"dbConns": {
		"*default": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mongo",
			"dbHost": "127.0.0.1",	
			"dbPort": 27017,
			"dbName": "cgrates",
			"dbUser": "cgrates"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"rates": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["conn1"]}],
		"*resources": [{"connIDs": ["conn1"]}]
	},
},


"attributes": {							// Attribute service
	"enabled": true,				// starts Attribute service: <true|false>.
},


"sessions": {
	"enabled": true,
	"conns":{
	"*rates": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"migrator": {
	"out_datadb_type": "mongo",
	"out_datadb_port": "27017",
	"out_datadb_name": "10",

	"usersFilters":["Account"],
},


"admins": {
	"enabled": true,
},


"filters": {								
	"conns": {
		"*accounts": [{"connIDs": ["*internal"]}]
	},
},

"accounts": {
    "enabled": true
},

}
