{
// CGRateS Configuration file
//
// Used for cgradmin
// Starts rater, scheduler


"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",				// RPC JSON listening address
	"rpcGOB": ":2013",					// RPC GOB listening address
	"http": ":2080",					// HTTP listening address
},


"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"dbConns": {
		"*default": {
			"dbType": "postgres",			 // db type: <internal|redis|mysql|mongo|postgres>
			"dbHost": "127.0.0.1",	
			"dbPort": 5432, 			 // db port to reach the database
			"dbName": "cgrates",		 // the host to connect to
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org" // password to use when connecting to the database
    	},
	},
},

"cdrs": {
	"enabled": true,					// start the CDR Server service:  <true|false>
},


"users": {
	"enabled": true,
	"indexes": ["Uuid"],
},


"resources": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"storeInterval": "1s",
	"conns": {
		"*thresholds": [{"ConnIDs": ["*internal"]}]
	},
},


"thresholds": {
	"enabled": true,
	"storeInterval": "1s",
},


"attributes": {
	"enabled": true,
},


"routes": {
	"enabled": true,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"ConnIDs": ["*internal"]}]
	},
},



"sessions": {
	"enabled": true,
	"conns":{
	"*chargers": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"Tenant": "",
			"FilterIDs": [],
			"ConnIDs": ["*internal"]
		 }
	]
			},
},


"admins": {
	"enabled": true,
},


"filters": {								
	"conns": {
		"*accounts": [{"ConnIDs": ["*internal"]}]
	},
},

"accounts": {
    "enabled": true
},

}
