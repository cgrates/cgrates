{

"general": {
	"nodeID": "Engine1"
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080"
},

"rpcConns": {
	"cacheConn": {
		"strategy": "*broadcast",
		"conns": [
			{"address": "*internal"},
			{"address": "127.0.0.1:20212", "transport":"*json"}
		]
	}
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"admins": {
	"enabled": true,
	"conns": {
		"*caches": [{"ConnIDs": ["cacheConn"]}]
	},
}

}
