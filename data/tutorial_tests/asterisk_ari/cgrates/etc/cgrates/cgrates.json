"general": {
	"nodeID":"CGRAsterisk",
	"replyTimeout": "5s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},




"schedulers": {
	"enabled": true,
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*localhost"]}],
		"*chargers": [{"connIDs": ["*internal"]}],
		"*rates": [{"connIDs": ["*internal"]}]
	},
	"opts": {
		"*rates": [
			{
				"tenant": "*any",
				"filterIDs": ["*notstring:~*req.RequestType:*none"],
				"value": true,
			},
		],
	},
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*accounts": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"asteriskAgent": {
	"enabled": true,
	"asteriskConns":[							
		{"address": "127.0.0.1:8088", "user": "cgrates",
			"password": "CGRateS.org", "connectAttempts": 3,"reconnects": 10,
		    "ariWebsocket": false }

	],
	"conns": {
		"*sessions":[{"connIDs":["*birpc_internal"]}]
	},
	"requestProcessors": [
		{
			"id": "StasisContinue",
			"filters": ["*string:~*req.type:StasisStart"],
			"flags": ["*none"]
		},
		{
			"id": "Initiate",
			"filters": [
				"*string:~*req.type:ChannelStateChange",
				"*string:~*req.channel.state:Up"
			],
			"flags": ["*initiate","*chargers","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"},
				{"tag": "RequestType", "path": "*cgreq.RequestType", "type": "*constant", "value": "*postpaid"},
				{"tag": "AnswerTime", "path": "*cgreq.AnswerTime", "type": "*variable", "value": "~*req.timestamp"}
			]
		},
		{
			"id": "IgnoreOther",
			"filters": ["*string:~*req.type:ChannelStateChange"],
			"flags": ["*none"]
		},
		{
			"id": "Terminate",
			"filters": ["*string:~*req.type:ChannelDestroyed"],
			"flags": ["*terminate","*accounts","*cdrs"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"},
				{"tag": "RequestType", "path": "*cgreq.RequestType", "type": "*constant", "value": "*postpaid"}
			]
		}
	]
},


"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"stats": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account","*req.RunID","*req.Destination"],
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],
	"stringIndexedFields": ["*req.Account"],
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"accounts": {
	"enabled": true,
	"conns": {
		"*rates": [{"connIDs": ["*internal"]}]
	},
},

"rates": {
	"enabled": true,
},


"admins": {
	"enabled": true,
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": "/tmp/cgr_asterisk_tutorial.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/tutorial",
		"tpOutPath": "",
	},
],
}
