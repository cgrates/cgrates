"general": {
	"nodeID":"CGRAsterisk",
	"replyTimeout": "5s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},




"schedulers": {
	"enabled": true,
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*localhost"],
	"stats_conns": ["*localhost"],
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*localhost"]}],
		"*chargers": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*localhost"],
	"sessions_cost_retries": 5,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"asteriskAgent": {
	"enabled": true,
	"asteriskConns":[							
		{"address": "127.0.0.1:8088", "user": "cgrates",
			"password": "CGRateS.org", "connectAttempts": 3,"reconnects": 10,
		    "ariWebsocket": false }

	],
	"conns": {
		"*sessions":[{"connIDs":["*birpc_internal"]}]
	},
	"requestProcessors": [
		{
			"id": "Authorize",
			"filters": ["*string:~*req.type:StasisStart"],
			"flags": ["*authorize","*accounts","*attributes"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"}
			],
			"replyFields":[
				{"tag": "CGR_Reqtype", "path": "*rep.cgr_reqtype", "type": "*constant", "value": "*prepaid"}
			]
		},
		{
			"id": "Initiate",
			"filters": [
				"*string:~*req.type:ChannelStateChange",
				"*string:~*req.channel.state:Up",
				"*string:~*req.channel.channelvars.cgr_reqtype:*prepaid"
			],
			"flags": ["*initiate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"},
				{"tag": "AnswerTime", "path": "*cgreq.AnswerTime", "type": "*variable", "value": "~*req.timestamp"}
			]
		},
		{
			"id": "Terminate",
			"filters": [
				"*string:~*req.type:ChannelDestroyed",
				"*string:~*req.channel.channelvars.cgr_reqtype:*prepaid"
			],
			"flags": ["*terminate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"}
			]
		},
		{
			"id": "IgnoreOutbound",
			"filters": ["*empty:~*req.channel.channelvars.cgr_reqtype:"],
			"flags": ["*none"]
		}
	]
},


"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"stats": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account","*req.RunID","*req.Destination"],
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*stats": [{"connIDs": ["*internal"]}],
		"*resources": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],	
	"stringIndexedFields": ["*req.Account"],
},


"admins": {
	"enabled": true,
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": ".cgr.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/tutorial",
		"tpOutPath": "",
	},
],
}
