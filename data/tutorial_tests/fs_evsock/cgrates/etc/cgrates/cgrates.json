"general": {
	"nodeID":"CGRFreeswitch",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},



"schedulers": {
	"enabled": true,
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*localhost"],
	"stats_conns": ["*localhost"],
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*localhost"]}]
	},
	"rals_conns": ["*localhost"],
	"sessions_cost_retries": 5,
},


"chargers": {
	"enabled": true,
	"conns": {
			"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*accounts": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},

"freeswitchAgent": {
	"enabled": true,
	"subscribePark": true,
	"eventSocketConns":[
		{"address": "127.0.0.1:8021", "password": "ClueCon", "reconnects": -1,"alias":""}
	],
	"conns": {
		"*sessions":[{"connIDs":["*birpc_internal"]}]
	},	
	"requestProcessors": [
		{
			"id": "Park",
			"filters": ["*string:~*req.Event-Name:CHANNEL_PARK"],
			"flags": ["*none","*log"]
		},
		{
			"id": "Initiate",
			"filters": ["*string:~*req.Event-Name:CHANNEL_ANSWER"],
			"flags": ["*initiate","*accounts","*log"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*fsr"},
				{"tag": "RequestType", "path": "*cgreq.RequestType", "type": "*constant", "value": "*postpaid"},
				{"tag": "Account", "path": "*cgreq.Account", "type": "*variable", "value": "~*req.variable_sip_from_user"},
				{"tag": "Subject", "path": "*cgreq.Subject", "type": "*variable", "value": "~*req.variable_sip_from_user"},
				{"tag": "FsConnID", "path": "*cgreq.FsConnID", "type": "*variable", "value": "~*vars.FsConnID"}
			],
			"replyFields":[
				{"tag": "OriginHost", "path": "*rep.cgr_originhost", "type": "*variable", "value": "~*vars.OriginHost"}
			]
		},
		{
			"id": "Terminate",
			"filters": ["*string:~*req.Event-Name:CHANNEL_HANGUP_COMPLETE"],
			"flags": ["*terminate","*accounts","*cdrs","*log"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*fsr"},
				{"tag": "RequestType", "path": "*cgreq.RequestType", "type": "*constant", "value": "*postpaid"},
				{"tag": "Account", "path": "*cgreq.Account", "type": "*variable", "value": "~*req.variable_sip_from_user"},
				{"tag": "Subject", "path": "*cgreq.Subject", "type": "*variable", "value": "~*req.variable_sip_from_user"}
			]
		}
	]
},


"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},

"rates": {
	"enabled": true,
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

"stats": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account","*req.RunID","*req.Destination"],
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*resources": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],	
	"stringIndexedFields": ["*req.Account"],
},

"accounts": {
	"enabled": true,
	"conns": {
		"*rates": [{"connIDs": ["*internal"]}]
	},
},

"admins": {
	"enabled": true,
},

"loaders": [
	{
		"id": "*default",
		"enabled": true,
		"tenant": "cgrates.org",
		"lockfilePath": ".cgr.lck",
		"tpInPath": "/usr/share/cgrates/tariffplans/tutorial",
		"tpOutPath": "",
	},
],

}
