"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},




"schedulers": {
	"enabled": true,
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*localhost"],
	"stats_conns": ["*localhost"],
	"attributes_conns": ["*internal"],
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*localhost"],
	"sessions_cost_retries": 5,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"listenBiJSON": "127.0.0.1:2014",		// address where to listen for bidirectional JSON-RPC requests
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},



"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},
	"stringIndexedFields": ["*req.Account"],
	"prefixIndexedFields": ["*req.Destination"],
},


"stats": {
	"enabled": true,
	"conns": {
		"*thresholds": [{"connIDs": ["*internal"]}]
	},	
	"stringIndexedFields": ["*req.Account"],
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*resources": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}]
	},
	"stringIndexedFields": ["*req.Account"],
	"prefixIndexedFields": ["*req.Destination"],
},


"admins": {
	"enabled": true,
},


}
