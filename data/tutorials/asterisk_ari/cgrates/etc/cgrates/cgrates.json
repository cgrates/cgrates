"general": {
	"nodeID":"CGRAsterisk",
	"replyTimeout": "5s",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},

"accounts": {
	"enabled": true,
	"conns": {
		"*rates": [{"connIDs": ["*localhost"]}]
	},
},


"schedulers": {
	"enabled": true,
},

"rates": {
	"enabled": true,
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*localhost"],
	"stats_conns": ["*localhost"],
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*localhost"]}]
	},
	"sessions_cost_retries": 5,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*accounts": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},
"db": {								// database used to store runtime data (eg: accounts, cdr stats)
	"dbConns": {
		"*default": {			// The id of the DB connection
			"dbType": "redis",	// db type: <internal|redis|mysql|mongo|postgres>
			"dbHost": "127.0.0.1",
			"dbPort": 6379, 	// db port to reach the database
			"dbName": "10", 	// db database name to connect to
			"dbUser": "cgrates", 
		},
		"StorDB": {						 // The id of the DB connection
			"dbType": "mysql",			 // db type: <internal|redis|mysql|mongo|postgres>
			"dbHost": "127.0.0.1",		 // the host to connect to
			"dbPort": 3306, 			 // db port to reach the database
			"dbName": "cgrates", 		 // db database name to connect to
			"dbUser": "cgrates", 		 // username to use when connecting to the database
			"dbPassword": "CGRateS.org" // password to use when connecting to the database
		},
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},

  

"asteriskAgent": {
	"enabled": true,
	"asteriskConns":[
		{"address": "127.0.0.1:8088", "user": "cgrates",
			"password": "CGRateS.org", "connectAttempts": 3,"reconnects": 10,
		    "ariWebsocket": false}

	],
	"conns": {
		"*sessions":[{"connIDs":["*bijsonLocalhost"]}]
	},
	"requestProcessors": [
		{
			"id": "Authorize",
			"filters": ["*string:~*req.type:StasisStart"],
			"flags": ["*authorize","*accounts","*attributes"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"}
			]
		},
		{
			"id": "SkipRinging",
			"filters": [
				"*string:~*req.type:ChannelStateChange",
				"*string:~*req.channel.state:Ringing",
			],
			"flags": ["*none"],
		},
		{
			"id": "Initiate",
			"filters": [
				"*string:~*req.type:ChannelStateChange",
				"*string:~*req.channel.state:Up",
			],
			"flags": ["*initiate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"},
				{"tag": "AnswerTime", "path": "*cgreq.AnswerTime", "type": "*variable", "value": "~*req.timestamp"}
			]
		},
		{
			"id": "Terminate",
			"filters": [
				"*string:~*req.type:ChannelDestroyed",
			],
			"flags": ["*terminate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*astr"}
			]
		}
	]
},


"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"stats": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account","*req.RunID","*req.Destination"],
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*resources": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],	
	"stringIndexedFields": ["*req.Account"],
},


"admins": {
	"enabled": true,
},


}
