"general": {
	"nodeID":"CGRFreeswitch",
},

"logger": {
	"level": 7
},

"listen": {
	"rpcJSON": ":2012",
	"rpcGOB": ":2013",
	"http": ":2080",
},


"schedulers": {
	"enabled": true,
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*localhost"],
	"stats_conns": ["*localhost"],
},


"cdrs": {
	"enabled": true,
	"conns": {
		"*chargers": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*localhost"]}]
	},
	"rals_conns": ["*localhost"],
	"sessions_cost_retries": 5,
},


"chargers": {
	"enabled": true,
	"conns": {
		"*attributes": [{"connIDs": ["*internal"]}]
	},
},


"sessions": {
	"enabled": true,
	"debitInterval": "5s",
	"channelSyncInterval":"7s",
	"conns":{
	"*rals": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*accounts": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*cdrs": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*resources": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*routes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*attributes": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*stats": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*thresholds": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*localhost"]
		 }
	],
	"*chargers": [
		 {
			"tenant": "",
			"filterIDs": [],
			"connIDs": ["*internal"]
		 }
	]
			},
},


"freeswitchAgent": {
	"enabled": true,
	"subscribePark": true,
	"eventSocketConns":[
		{"address": "127.0.0.1:8021", "password": "ClueCon", "reconnects": -1,"alias":""}
	],
	"conns": {
		"*sessions":[{"connIDs":["*bijsonLocalhost"]}]
	},
	"requestProcessors": [
		{
			"id": "Authorize",
			"filters": ["*string:~*req.Event-Name:CHANNEL_PARK"],
			"flags": ["*authorize","*accounts","*resources:false","*routes","*attributes"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*fsr"}
			],
		},
		{
			"id": "Initiate",
			"filters": ["*string:~*req.Event-Name:CHANNEL_ANSWER"],
			"flags": ["*initiate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*fsr"},
				{"tag": "FsConnID", "path": "*cgreq.FsConnID", "type": "*variable", "value": "~*vars.FsConnID"}
			],
		},
		{
			"id": "TerminateAndCDR",
			"filters": ["*string:~*req.Event-Name:CHANNEL_HANGUP_COMPLETE"],
			"flags": ["*terminate","*accounts"],
			"requestFields":[
				{"tag": "BaseTmpl", "type": "*template", "value": "*fsr"}
			]
		 },
	]
},


"attributes": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],			
},


"resources": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"rates": {
	"enabled": true,
},

"accounts": {
	"enabled": true,
	"conns": {
		"*rates": [{"connIDs": ["*internal"]}]
	},
},


"stats": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account","*req.RunID","*req.Destination"],
},

"db": {
	"dbConns": {
		"*default": {
			"dbType": "redis",
			"dbHost": "127.0.0.1",
			"dbPort": 6379,
			"dbName": "10",
			"dbUser": "cgrates"
		},
		"StorDB": {
			"dbType": "mysql",
			"dbHost": "127.0.0.1",
			"dbPort": 3306,
			"dbName": "cgrates",
			"dbUser": "cgrates",
			"dbPassword": "CGRateS.org"
		}
	},
	"items": {
		"*cdrs": {"limit": -1, "ttl": "", "staticTTL": false, "remote":false, "replicate":false, "dbConn": "StorDB"}
	}
},


"thresholds": {
	"enabled": true,
	"stringIndexedFields": ["*req.Account"],
},


"routes": {
	"enabled": true,
	"conns": {
		"*resources": [{"connIDs": ["*internal"]}],
		"*stats": [{"connIDs": ["*internal"]}]
	},
	"rals_conns": ["*internal"],	
	"stringIndexedFields": ["*req.Account"],
},


"admins": {
	"enabled": true,
},


}
